# Canonical site URL (build-time: sitemap/OG). On Coolify set via SERVICE_URL_WEB.
PUBLIC_SITE_URL=https://mens-circle.de

# Runtime app URL (used in email links, the hosted .ics URL, image URLs).
APP_URL=https://mens-circle.de
MAIL_FROM_ADDRESS=hallo@mens-circle.de
MAIL_FROM_NAME=Männerkreis Niederbayern/ Straubing
MAIL_ADMIN_ADDRESS=hallo@mens-circle.de
MAIL_ADMIN_NAME=Männerkreis Admin
MAIL_CONTACT_ADDRESS=hallo@mens-circle.de

# SQLite database file (Drizzle / bun:sqlite). In Docker this lives in the
# mounted /data volume; locally it defaults to ./data/mens-circle.db.
DATABASE_PATH=./data/mens-circle.db

# Admin UI — single operator login + a long random secret that signs the
# session cookie. Without these the /admin area is unusable.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# listmonk — newsletter subscribers, per-event lists AND transactional email.
# URL is the internal service in docker-compose.
LISTMONK_URL=http://listmonk:9000
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
# Numeric list ID(s), comma-separated — e.g. "1" or "1,2".
# Use the numeric ID from listmonk → Lists (URL .../admin/lists/<ID>), NOT the
# list UUID.
LISTMONK_LIST_IDS=

# Numeric IDs of the listmonk *transactional* templates (Admin → Campaigns →
# Templates → type "Transactional"). Create them once from the HTML sources in
# listmonk/tx-templates/ (see listmonk/tx-templates/README.md). If a value is
# empty the corresponding email is skipped (and logged).
LISTMONK_TX_REGISTRATION_CONFIRMATION=
LISTMONK_TX_WAITLIST_CONFIRMATION=
LISTMONK_TX_ADMIN_NOTIFICATION=
LISTMONK_TX_WAITLIST_PROMOTION=
LISTMONK_TX_EVENT_REMINDER=
LISTMONK_TX_EVENT_MESSAGE=

# Coolify auto-generates these (docker-compose magic vars): SERVICE_URL_WEB,
# SERVICE_URL_LISTMONK, SERVICE_USER/PASSWORD_POSTGRES, SERVICE_*_LISTMONKADMIN.
