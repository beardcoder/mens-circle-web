# ─────────────────────────────────────────────────────────────────────────
# Frontend (Astro) — build & runtime
# ─────────────────────────────────────────────────────────────────────────
# Canonical site URL (used for SEO, sitemap, OG tags).
PUBLIC_SITE_URL=https://mens-circle.de

# PocketBase API base URL the browser talks to.
# In production the frontend is served BY PocketBase on the same origin, so
# leave this empty to use a relative/same-origin base. Set it only for local
# dev when Astro (4321) and PocketBase (8090) run on different ports.
PUBLIC_PB_URL=

# Build-time data source. Events + testimonials are fetched from the LIVE
# PocketBase during `bun run build` and baked into the static HTML. Point this
# at the running instance. If unset/unreachable (e.g. the very first deploy),
# pages render their empty state and the first content change triggers a rebuild
# that picks the data up. In Coolify set this as a BUILD ARG (Build Variable).
PB_URL=https://mens-circle.de

# ─────────────────────────────────────────────────────────────────────────
# PocketBase — read by pb_hooks (config.pb.js) via $os.getenv()
# ─────────────────────────────────────────────────────────────────────────
# Public site URL used inside emails (event links, unsubscribe, iCal UID).
APP_URL=https://mens-circle.de

# Transactional email "from" identity.
MAIL_FROM_ADDRESS=hallo@mens-circle.de
MAIL_FROM_NAME=Männerkreis Niederbayern/ Straubing

# Where admin notifications (new registration etc.) are sent.
MAIL_ADMIN_ADDRESS=hallo@mens-circle.de
MAIL_ADMIN_NAME=Männerkreis Admin

# SMTP is configured in the PocketBase admin UI (Settings → Mail settings)
# OR seeded on first boot from these vars by the bootstrap migration:
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# First-run superuser (admin) — created automatically on first boot if set.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────
# Deploy webhook — rebuild the static site when events/testimonials change
# ─────────────────────────────────────────────────────────────────────────
# Events + testimonials are baked into the HTML at build time, so a change only
# shows after a rebuild. A PocketBase hook (pb_hooks/deploy.pb.js) pings this
# webhook on create/update/delete, debounced (leading edge + minute-cron
# trailing sweep). Without DEPLOY_WEBHOOK_URL the whole thing is a no-op.
#
# Coolify: create an API token (Keys & Tokens → API Tokens) and take the
# resource UUID from the app URL. Coolify's deploy API is GET + Bearer auth:
#   DEPLOY_WEBHOOK_URL=https://<coolify-host>/api/v1/deploy?uuid=<resource-uuid>&force=false
#   DEPLOY_WEBHOOK_METHOD=GET
#   DEPLOY_WEBHOOK_TOKEN=<coolify-api-token>   →  sent as: Authorization: Bearer <token>
DEPLOY_WEBHOOK_URL=
DEPLOY_WEBHOOK_METHOD=GET
DEPLOY_WEBHOOK_TOKEN=
# Min seconds between rebuilds (burst of edits → ≤2 builds). Default 60.
DEPLOY_COOLDOWN_SEC=60
