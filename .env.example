# ─────────────────────────────────────────────────────────────────────────
# Frontend (Astro) — build & runtime
# ─────────────────────────────────────────────────────────────────────────
# Canonical site URL (used for SEO, sitemap, OG tags).
PUBLIC_SITE_URL=https://mens-circle.de

# API base URL the browser talks to.
# In production the single Bun process serves everything on the same origin,
# so leave this empty. Set only if you run a separate dev API server.
PUBLIC_API_URL=

# ─────────────────────────────────────────────────────────────────────────
# EmDash — embedded backend (bun:sqlite)
# ─────────────────────────────────────────────────────────────────────────
# Path to the SQLite database file. In Docker, mount a volume at /app/data.
DATABASE_PATH=./data/emdash.db

# Public site URL used inside emails (event links, unsubscribe, iCal UID).
APP_URL=https://mens-circle.de

# Transactional email "from" identity.
MAIL_FROM_ADDRESS=hallo@mens-circle.de
MAIL_FROM_NAME=Männerkreis Niederbayern/ Straubing

# Where admin notifications (new registration etc.) are sent.
MAIL_ADMIN_ADDRESS=hallo@mens-circle.de
MAIL_ADMIN_NAME=Männerkreis Admin

# Contact email shown in transactional emails.
MAIL_CONTACT_ADDRESS=hallo@mens-circle.de

# SMTP configuration for transactional emails.
# Leave SMTP_HOST empty to disable email sending (mails will be logged instead).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# NOTE: Events + testimonials render on demand (SSR) from the embedded SQLite
# database, so there is no build-time data fetch — a content change via the API
# is live immediately.
