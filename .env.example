# ─────────────────────────────────────────────────────────────────────────
# Frontend (Astro) — build & runtime
# ─────────────────────────────────────────────────────────────────────────
# Canonical site URL (used for SEO, sitemap, OG tags).
PUBLIC_SITE_URL=https://mens-circle.de

# PocketBase API base URL the browser talks to.
# In production the Bun edge serves the site and reverse-proxies /api/* to
# PocketBase on the same origin, so leave this empty to use a same-origin base.
# Set it only for local dev when Astro (4321) and PocketBase (8090) run on
# different ports.
PUBLIC_PB_URL=

# Runtime data source for SSR (server-only). The Bun edge fetches events +
# testimonials from the co-located PocketBase per request. In production the
# entrypoint sets this to the loopback address automatically — you normally do
# NOT need to set it. Override only for an external PocketBase or local dev.
# PB_INTERNAL_URL=http://127.0.0.1:8091

# ─────────────────────────────────────────────────────────────────────────
# PocketBase — read by pb_hooks (config.pb.js) via $os.getenv()
# ─────────────────────────────────────────────────────────────────────────
# Public site URL used inside emails (event links, unsubscribe, iCal UID).
APP_URL=https://mens-circle.de

# Transactional email "from" identity.
MAIL_FROM_ADDRESS=hallo@mens-circle.de
MAIL_FROM_NAME=Männerkreis Niederbayern/ Straubing

# Where admin notifications (new registration etc.) are sent.
MAIL_ADMIN_ADDRESS=hallo@mens-circle.de
MAIL_ADMIN_NAME=Männerkreis Admin

# SMTP is configured in the PocketBase admin UI (Settings → Mail settings)
# OR seeded on first boot from these vars by the bootstrap migration:
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# First-run superuser (admin) — created automatically on first boot if set.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# NOTE: Events + testimonials now render on demand (SSR) from PocketBase, so
# there is no build-time data fetch and no rebuild-on-content-change webhook —
# a content change in the admin is live immediately. The former
# DEPLOY_WEBHOOK_* variables are no longer used.
