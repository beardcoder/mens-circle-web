# Canonical site URL (build-time: sitemap/OG). On Coolify set via SERVICE_URL_WEB.
PUBLIC_SITE_URL=https://mens-circle.de

# Public URL (used in email links, iCal, image URLs).
APP_URL=https://mens-circle.de

# Where the SQLite database + uploaded images live. In Docker this is /data
# (a mounted volume); locally it defaults to ./data.
# DATA_DIR=./data
# DATABASE_PATH=./data/app.db

# Transactional event mails.
MAIL_FROM_ADDRESS=hallo@mens-circle.de
MAIL_FROM_NAME=Männerkreis Niederbayern/ Straubing
MAIL_ADMIN_ADDRESS=hallo@mens-circle.de
MAIL_ADMIN_NAME=Männerkreis Admin

# SMTP for the transactional event mails (nodemailer). Leave SMTP_HOST empty to
# disable sending (mails are logged instead — handy in local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# Admin login for the built-in admin at /admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Signs the admin session cookie — set a long random string in production
# (otherwise a random per-boot secret is used and sessions drop on restart).
SESSION_SECRET=
# Guards the internal reminder-cron endpoint (/api/internal/cron/*). The
# in-process scheduler only runs when this is set; an external scheduler
# (e.g. a Cloudflare Cron Trigger) can call the endpoint with this secret too.
CRON_SECRET=

# Newsletter → listmonk. URL is the internal service in docker-compose.
LISTMONK_URL=http://listmonk:9000
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
# Numeric list ID(s), comma-separated — e.g. "1" or "1,2".
# Use the numeric ID from listmonk → Lists (URL .../admin/lists/<ID>), NOT the list UUID.
LISTMONK_LIST_IDS=

# Coolify auto-generates these (docker-compose magic vars): SERVICE_URL_WEB,
# SERVICE_URL_LISTMONK, SERVICE_USER/PASSWORD_POSTGRES, SERVICE_*_LISTMONKADMIN.
