# ─────────────────────────────────────────────────────────────────────────
# Frontend (Astro) — build & runtime
# ─────────────────────────────────────────────────────────────────────────
# Canonical site URL (used for SEO, sitemap, OG tags).
PUBLIC_SITE_URL=https://mens-circle.de

# PocketBase API base URL the browser talks to.
# In production the Bun edge serves the site and reverse-proxies /api/* to
# PocketBase on the same origin, so leave this empty to use a same-origin base.
# Set it only for local dev when Astro (4321) and PocketBase (8090) run on
# different ports.
PUBLIC_PB_URL=

# Runtime data source for SSR (server-only). The Bun edge fetches events +
# testimonials from the co-located PocketBase per request. In production the
# entrypoint sets this to the loopback address automatically — you normally do
# NOT need to set it. Override only for an external PocketBase or local dev.
# PB_INTERNAL_URL=http://127.0.0.1:8091

# ─────────────────────────────────────────────────────────────────────────
# PocketBase — read by pb_hooks (config.pb.js) via $os.getenv()
# ─────────────────────────────────────────────────────────────────────────
# Public site URL used inside emails (event links, iCal UID).
APP_URL=https://mens-circle.de

# Transactional email "from" identity. Used only for event mails
# (registration, waitlist, reminders). The newsletter is sent by listmonk.
MAIL_FROM_ADDRESS=hallo@mens-circle.de
MAIL_FROM_NAME=Männerkreis Niederbayern/ Straubing

# Where admin notifications (new registration etc.) are sent.
MAIL_ADMIN_ADDRESS=hallo@mens-circle.de
MAIL_ADMIN_NAME=Männerkreis Admin

# SMTP is configured in the PocketBase admin UI (Settings → Mail settings)
# OR seeded on first boot from these vars by the bootstrap migration. Powers
# the transactional EVENT emails only — the newsletter has its own SMTP set up
# inside listmonk:
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# First-run superuser (admin) — created automatically on first boot if set.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────
# listmonk — newsletter subscribers + campaigns
# ─────────────────────────────────────────────────────────────────────────
# The public POST /api/newsletter/subscribe route (a PocketBase hook) forwards
# new sign-ups to listmonk's admin API. listmonk owns the subscriber list, the
# (double) opt-in confirmation email, campaign sending and the unsubscribe page.
#
# Base URL of the listmonk instance. In the single-stack docker-compose the
# web app reaches listmonk over the internal network, so leave this as the
# service URL. (For a separate/external listmonk, set its public https URL.)
LISTMONK_URL=http://listmonk:9000
# API user + token (listmonk admin → Settings → API users). Auth uses the
# "Authorization: token <user>:<token>" scheme.
LISTMONK_API_USER=
LISTMONK_API_TOKEN=
# Target list ID(s) new subscribers are added to. Comma-separate for multiple
# (e.g. "1,3"). These are the numeric list IDs from the listmonk admin.
LISTMONK_LIST_IDS=

# ─────────────────────────────────────────────────────────────────────────
# Coolify-managed (docker-compose magic variables) — you do NOT set these
# ─────────────────────────────────────────────────────────────────────────
# On Coolify the single docker-compose.yml generates these automatically:
#   SERVICE_FQDN_WEB_8090 / SERVICE_URL_WEB          → web domain, APP_URL
#   SERVICE_FQDN_LISTMONK_9000 / SERVICE_URL_LISTMONK→ listmonk domain
#   SERVICE_USER_POSTGRES / SERVICE_PASSWORD_POSTGRES→ listmonk DB credentials
#   SERVICE_USER_LISTMONKADMIN / SERVICE_PASSWORD_LISTMONKADMIN → super admin
# (For a plain `docker compose up` outside Coolify, set those yourself.)

# NOTE: Events + testimonials render on demand (SSR) from PocketBase, so there
# is no build-time data fetch. listmonk's own SMTP is configured inside listmonk
# (Settings → SMTP), separate from the SMTP_* above (which powers event mails).
