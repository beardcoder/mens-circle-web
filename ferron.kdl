// ─────────────────────────────────────────────────────────────────────────────
// Männerkreis — edge config (Ferron, https://www.ferron.sh).
//
// Ferron is the single entrypoint inside the container. It serves the pre-built
// static Astro site DIRECTLY (full control over Cache-Control + security
// headers) and reverse-proxies only the dynamic paths to PocketBase, which
// listens on a loopback-only port.
//
//   Coolify (TLS) ──http──▶ Ferron :8090 ─┬─ static /srv/site  (Astro dist)
//                                          └─ proxy  127.0.0.1:8091  (PocketBase)
//
// TLS is terminated by Coolify's reverse proxy, so Ferron speaks plain HTTP.
// ─────────────────────────────────────────────────────────────────────────────

globals {
	// Listen on all IPv4 interfaces so Coolify's proxy can reach the container.
	listen_ip "0.0.0.0"

	// Trust the X-Forwarded-For set by Coolify's outer proxy so {client_ip}
	// (and the XFF forwarded to PocketBase) resolves to the real visitor instead
	// of Coolify's proxy IP. Safe here because the container is only reachable
	// through Coolify. This is what makes PocketBase's per-visitor rate limiting
	// work (see pb_hooks/config.pb.js → trustedProxies + useLeftmostIP).
	trust_x_forwarded_for #true
}

// ── Reusable snippets (applied with `use`) ──────────────────────────────────
snippet "security_headers" {
	header "X-Content-Type-Options" "nosniff"
	header "Referrer-Policy" "strict-origin-when-cross-origin"
	header "X-Frame-Options" "SAMEORIGIN"
}
// Content-hashed assets + fonts never change under a given URL → 1 year.
snippet "cache_immutable" {
	file_cache_control "public, max-age=31536000, immutable"
	compressed
	etag
}
// Other images, incl. modern formats (avif, webp, jxl) → 7 days.
snippet "cache_images" {
	file_cache_control "public, max-age=604800"
	etag
}
// Manifests, feeds, robots → 1 day.
snippet "cache_meta" {
	file_cache_control "public, max-age=86400"
	etag
}

:8090 {
	// Static Astro site. `root` lives at host level on purpose: the cache
	// conditions below attach file_cache_control to it via `use`, and a nested
	// block does NOT inherit `root` — files matched there would 404.
	root "/srv/site"

	// Security headers (inherited by the condition matches below too).
	use "security_headers"

	// Default cache policy: HTML + extensionless clean routes (/event,
	// /impressum) must reflect new deploys, so they always revalidate. The
	// asset-class conditions below override this for cacheable files.
	file_cache_control "public, max-age=0, must-revalidate"

	// ── Dynamic paths owned by PocketBase ───────────────────────────────────
	// API + admin UI (/_/) + the HTML routes from pb_hooks (newsletter
	// unsubscribe page, /events/{slug} → /event/{slug} redirect).
	// remove_base=#false forwards the full path unchanged to PocketBase.
	// "/events/" carries a trailing slash so the bare /events (Astro's static
	// → /event redirect) keeps being served from disk.
	location "/api" remove_base=#false {
		proxy "http://127.0.0.1:8091"
	}
	location "/_" remove_base=#false {
		proxy "http://127.0.0.1:8091"
	}
	location "/newsletter" remove_base=#false {
		proxy "http://127.0.0.1:8091"
	}
	location "/events/" remove_base=#false {
		proxy "http://127.0.0.1:8091"
	}

	// ── Cache-Control by asset class (static files only) ────────────────────
	condition "IMMUTABLE_ASSETS" {
		is_regex "{path}" #"^/assets/|\.(woff2?|ttf|otf|eot)$"# case_insensitive=#true
	}
	if "IMMUTABLE_ASSETS" {
		use "cache_immutable"
	}

	condition "IMAGES" {
		is_regex "{path}" #"\.(avif|webp|jxl|png|jpe?g|gif|svg|ico)$"# case_insensitive=#true
	}
	if "IMAGES" {
		use "cache_images"
	}

	condition "META" {
		is_regex "{path}" #"\.xml$|^/(manifest\.json|manifest\.webmanifest|robots\.txt|browserconfig\.xml)$"# case_insensitive=#true
	}
	if "META" {
		use "cache_meta"
	}
}
