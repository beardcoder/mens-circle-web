# listmonk deploy env — set these as Coolify environment variables.

# ── PostgreSQL (db service in docker-compose.yml) ──────────────────────────
POSTGRES_USER=listmonk
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=listmonk

# ── listmonk super admin (created on first boot) ───────────────────────────
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=change-me-to-something-strong

# ── Only needed for the STANDALONE Dockerfile (external Postgres) ──────────
# With docker-compose.yml these are set automatically from the values above.
# LISTMONK_app__address=0.0.0.0:9000
# LISTMONK_db__host=your-postgres-host
# LISTMONK_db__port=5432
# LISTMONK_db__user=listmonk
# LISTMONK_db__password=change-me-to-something-strong
# LISTMONK_db__database=listmonk
# LISTMONK_db__ssl_mode=disable

# NOTE: SMTP for sending is configured inside listmonk (Settings → SMTP),
# not via these env vars.
