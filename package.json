{
  "name": "mens-circle-web",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "description": "Männerkreis Niederbayern/ Straubing — Astro 6 + Svelte 5, SSR on the Bun runtime, with EmDash (bun:sqlite) as the embedded backend.",
  "scripts": {
    "dev": "bun --bun astro dev",
    "build": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "start": "bun run dist/server/entry.mjs",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "import:live": "bun run scripts/import-live-data.ts"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^8.1.2",
    "@yeskunall/astro-umami": "^0.0.9",
    "astro": "^6.4.6",
    "leaflet": "^1.9.4",
    "motion": "^12.40.0",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/bun": "^1.3.14",
    "@types/leaflet": "^1.9.21",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.0",
    "typescript": "^6.0.3"
  }
}
