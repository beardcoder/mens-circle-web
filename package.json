{
  "name": "mens-circle-web",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Männerkreis Niederbayern/ Straubing — Astro 7 + Svelte 5, SSR on the Bun runtime, with Drizzle (bun:sqlite) as the backend and listmonk for email.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "bun run dist/server/entry.mjs",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "import:pb": "bun run scripts/import-pocketbase.ts"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "9.0.0-beta.4",
    "@yeskunall/astro-umami": "^0.0.9",
    "astro": "7.0.0-beta.5",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "motion": "^12.40.0",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/leaflet": "^1.9.21",
    "astro-eslint-parser": "^1.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
