{
  "name": "mens-circle-web",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Männerkreis Niederbayern/ Straubing — Astro 6 + Svelte 5, SSR on the Bun runtime, with PocketBase as the backend.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "bun run dist/server/entry.mjs",
    "check": "astro check",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "biome:check": "biome check .",
    "import:live": "bun run scripts/import-live-data.ts",
    "pb:dev": "./pocketbase/pocketbase serve --dir ./pocketbase/pb_data --hooksDir ./pocketbase/pb_hooks --migrationsDir ./pocketbase/pb_migrations"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^8.1.2",
    "@yeskunall/astro-umami": "^0.0.9",
    "astro": "^6.4.6",
    "leaflet": "^1.9.4",
    "motion": "^12.40.0",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@types/leaflet": "^1.9.21",
    "typescript": "^6.0.3"
  }
}
