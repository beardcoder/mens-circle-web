    "motion": "^12.40.0",
    "nodemailer": "^9.0.1",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/leaflet": "^1.9.21",
