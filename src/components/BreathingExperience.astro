---
import { BREATHING_STEPS, BREATHING_WARNING } from '@lib/breathing';
import BreathingApp from './islands/BreathingApp.svelte';

interface Props {
  /** Full-screen, chrome-less app surface (the installable standalone route).
   *  When false the exercise sits inside the normal site page: it is sized to
   *  its content and the floating info button + modal are dropped, because the
   *  embedding page shows the instructions inline. */
  standalone?: boolean;
}

const { standalone = false } = Astro.props;
---

<section class:list={['breathing-section', standalone ? 'breathing-screen' : 'breathing-embed']}>
  {
    standalone && (
      <button
        type="button"
        class="breathing-info-btn"
        id="info-open"
        aria-haspopup="dialog"
        aria-label="So funktioniert es"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" />
          <path d="M12 11v5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <circle cx="12" cy="7.5" r="1.25" fill="currentColor" />
        </svg>
      </button>
    )
  }

  {standalone && <h1 class="sr-only">Atemübung</h1>}

  <BreathingApp client:visible />

  {
    standalone && (
      <dialog class="info-modal" id="info-modal" aria-labelledby="info-title">
        <div class="info-modal__content">
          <button type="button" class="info-modal__close" id="info-close" aria-label="Schließen">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M6 6l12 12M18 6L6 18"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
          </button>

          <h2 id="info-title">So funktioniert es</h2>
          <ol class="breathing__steps">
            {BREATHING_STEPS.map((step) => (
              <li>
                <strong>{step.title}:</strong> {step.text}
              </li>
            ))}
          </ol>
          <p class="breathing__warning">
            <strong>Wichtig:</strong> {BREATHING_WARNING}
          </p>

          <button type="button" id="pwa-install" class="breathing__install" hidden>
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            Als App installieren
          </button>
        </div>
      </dialog>
    )
  }
</section>

<script>
  // Instructions live in a native <dialog> opened from the floating info button
  // (standalone surface only). showModal() gives the focus trap, Escape-to-close
  // and backdrop for free; a click outside the card also closes it. The queries
  // no-op on the embedded page, where these elements aren't rendered.
  const infoModal = document.querySelector<HTMLDialogElement>('#info-modal');
  const infoOpen = document.querySelector<HTMLButtonElement>('#info-open');
  const infoClose = document.querySelector<HTMLButtonElement>('#info-close');

  infoOpen?.addEventListener('click', () => {
    if (infoModal && !infoModal.open) infoModal.showModal();
  });

  infoClose?.addEventListener('click', () => infoModal?.close());

  infoModal?.addEventListener('click', (event) => {
    if (event.target !== infoModal) return;

    const r = infoModal.getBoundingClientRect();
    const inside =
      event.clientX >= r.left && event.clientX <= r.right && event.clientY >= r.top && event.clientY <= r.bottom;

    if (!inside) infoModal.close();
  });
</script>

<style is:global>
  /* @property kept unlayered — must be at top level for interpolation to work */
  @property --ring-scale {
    syntax: '<number>';
    initial-value: 1;
    inherits: true;
  }

  @layer sections {
    .breathing-section {
      --breathing-bg: var(--color-earth-deep);
      --breathing-bg-deep: var(--color-ink);
      --breathing-accent: var(--color-terracotta-light);
      --breathing-accent-dim: var(--color-terracotta);
      --breathing-warm: var(--color-sand);
      --_surface-noise-opacity: 0.03;

      position: relative;
      background:
        radial-gradient(
          ellipse at 50% 0%,
          color-mix(in oklch, var(--breathing-accent-dim) 14%, transparent),
          transparent 60%
        ),
        radial-gradient(
          ellipse at 85% 92%,
          color-mix(in oklch, var(--breathing-warm) 10%, transparent),
          transparent 55%
        ),
        linear-gradient(160deg, var(--breathing-bg) 0%, var(--breathing-bg-deep) 100%);
      overflow: hidden;
      color: var(--text-on-dark);
    }

    .breathing-section::before {
      z-index: 0;
    }

    /* Keep the app to one screen: the global `body { min-block-size: 100dvh }`
       would otherwise add a scrollable strip (the browser-toolbar delta) below
       the 100svh screen. Pinning the bare body to svh removes it, so the page
       doesn't scroll in the common case (it still can if content genuinely
       overflows on very short screens). */
    body.is-bare {
      min-block-size: 100svh;
    }

    /* Full-screen app surface. It fills the viewport and centres the experience
       when it fits, but is allowed to grow (and let the page scroll) instead of
       clipping the controls off the bottom on short phones — the previous fixed
       `block-size + overflow: clip` made the start button and settings
       unreachable there. svh, not dvh: dvh mis-resolves on iOS PWA cold start
       and jumps as the toolbar shows/hides; 100vh is the old-browser fallback. */
    .breathing-screen {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding-inline: max(var(--space-md), var(--safe-area-inset-left))
        max(var(--space-md), var(--safe-area-inset-right));
      padding-block: max(var(--space-md), var(--safe-area-inset-top))
        max(var(--space-md), var(--safe-area-inset-bottom));
      min-block-size: 100vh;
      min-block-size: 100svh;
      /* Contain the soft ring glow horizontally without trapping vertical scroll. */
      overflow-x: clip;
    }

    /* Natural height inside the centred column (the base `block-size: 100%` only
       makes sense for the old fixed-height grid). */
    .breathing-screen .breathing-app {
      block-size: auto;
    }

    /* Embedded surface: the same experience sitting inside the normal site
       page. It is sized to a generous slab (not the whole viewport) so the
       header above and the page content below stay in view. */
    .breathing-embed {
      display: grid;
      justify-items: center;
      padding-inline: max(var(--space-md), var(--safe-area-inset-left))
        max(var(--space-md), var(--safe-area-inset-right));
      padding-block: var(--space-xl);
    }

    /* Auto height (not a fixed slab) so the circle keeps its natural size and
       the controls/settings flow below it — the min keeps a generous, calm
       stage without ever crushing the circle into the panel beneath it. */
    .breathing-embed .breathing-app {
      block-size: auto;
      min-block-size: clamp(34rem, 82svh, 50rem);
    }

    .breathing-screen > * {
      position: relative;
      z-index: 1;
    }

    /* Floating info button — opens the instructions dialog. */
    .breathing-info-btn {
      display: grid;
      position: absolute;
      place-items: center;
      z-index: 2;
      backdrop-filter: blur(8px);
      transition:
        color var(--motion-quick),
        background-color var(--motion-quick);
      cursor: pointer;
      inset-block-start: max(var(--space-sm), var(--safe-area-inset-top));
      inset-inline-end: max(var(--space-sm), var(--safe-area-inset-right));
      border: 1px solid color-mix(in oklch, var(--color-sand) 16%, transparent);
      border-radius: var(--radius-full);
      background: color-mix(in oklch, var(--color-sand) 8%, transparent);
      inline-size: 2.75rem;
      block-size: 2.75rem;
      color: color-mix(in oklch, var(--text-on-dark) 70%, transparent);
    }

    @media (hover: hover) and (pointer: fine) {
      .breathing-info-btn:hover {
        background: color-mix(in oklch, var(--color-sand) 16%, transparent);
        color: var(--text-on-dark);
      }
    }

    .breathing-info-btn:focus-visible {
      outline: 2px solid var(--breathing-accent);
      outline-offset: 3px;
    }

    .breathing-info-btn svg {
      inline-size: 1.4rem;
      block-size: 1.4rem;
    }

    /* Instructions dialog (native <dialog> + showModal): focus trap, Escape
       and backdrop for free, with a smooth open/close via @starting-style. */
    .info-modal {
      translate: 0 12px;
      scale: 0.96;
      opacity: 0;
      transition:
        opacity var(--motion-standard),
        scale var(--motion-standard),
        translate var(--motion-standard),
        overlay var(--motion-standard) allow-discrete,
        display var(--motion-standard) allow-discrete;
      margin: auto;
      box-shadow: var(--shadow-2xl);
      border: 1px solid color-mix(in oklch, var(--color-sand) 16%, transparent);
      border-radius: var(--radius-lg);
      background: color-mix(in oklch, var(--breathing-bg) 86%, black);
      padding: 0;
      inline-size: min(420px, calc(100vw - 2 * var(--space-md)));
      max-block-size: calc(100dvh - 2 * var(--space-md));
      color: var(--text-on-dark);
    }

    .info-modal[open] {
      translate: 0 0;
      scale: 1;
      opacity: 1;
    }

    @starting-style {
      .info-modal[open] {
        translate: 0 12px;
        scale: 0.96;
        opacity: 0;
      }
    }

    .info-modal::backdrop {
      backdrop-filter: blur(0);
      transition:
        background-color var(--motion-standard),
        backdrop-filter var(--motion-standard),
        overlay var(--motion-standard) allow-discrete,
        display var(--motion-standard) allow-discrete;
      background-color: color-mix(in oklch, black 0%, transparent);
    }

    .info-modal[open]::backdrop {
      backdrop-filter: blur(4px);
      background-color: color-mix(in oklch, black 55%, transparent);
    }

    @starting-style {
      .info-modal[open]::backdrop {
        backdrop-filter: blur(0);
        background-color: color-mix(in oklch, black 0%, transparent);
      }
    }

    .info-modal__content {
      position: relative;
      padding: var(--space-lg);
      max-block-size: calc(100dvh - 2 * var(--space-md));
      overflow-y: auto;
    }

    .info-modal__close {
      display: grid;
      position: absolute;
      place-items: center;
      transition:
        color var(--motion-quick),
        background-color var(--motion-quick);
      cursor: pointer;
      inset-block-start: var(--space-xs);
      inset-inline-end: var(--space-xs);
      border: none;
      border-radius: var(--radius-full);
      background: none;
      inline-size: 2.25rem;
      block-size: 2.25rem;
      color: color-mix(in oklch, var(--text-on-dark) 65%, transparent);
    }

    @media (hover: hover) and (pointer: fine) {
      .info-modal__close:hover {
        background: color-mix(in oklch, var(--color-sand) 12%, transparent);
        color: var(--text-on-dark);
      }
    }

    .info-modal__close:focus-visible {
      outline: 2px solid var(--breathing-accent);
      outline-offset: 2px;
    }

    .info-modal__close svg {
      inline-size: 1.25rem;
      block-size: 1.25rem;
    }

    .info-modal__content h2 {
      margin-block-end: var(--space-md);
      color: var(--text-on-dark);
      font-weight: 500;
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-family: var(--font-display);
      letter-spacing: -0.01em;
    }

    @media (prefers-reduced-motion: reduce) {
      .info-modal {
        translate: 0;
        scale: 1;
        transition:
          opacity var(--motion-quick),
          overlay var(--motion-quick) allow-discrete,
          display var(--motion-quick) allow-discrete;
      }

      @starting-style {
        .info-modal[open] {
          translate: 0;
          scale: 1;
        }
      }

      .info-modal::backdrop,
      .info-modal[open]::backdrop {
        backdrop-filter: none;
      }
    }

    .breathing__steps {
      margin-block-end: var(--space-md);
      padding-inline-start: 1.25rem;
      color: color-mix(in oklch, var(--text-on-dark) 72%, transparent);
      font-size: var(--text-section-body);
      line-height: var(--leading-relaxed);
    }

    .breathing__steps li {
      margin-block-end: var(--space-xs);
    }

    .breathing__steps strong {
      color: var(--text-on-dark);
    }

    .breathing__warning {
      border-radius: var(--radius-md);
      border-inline-start: 3px solid var(--color-warning);
      background: color-mix(in oklch, var(--color-warning) 12%, transparent);
      padding: var(--space-sm) var(--space-md);
      color: var(--text-on-dark);
      font-size: 0.9375rem;
    }

    /* Shown only when the browser offers a native install (beforeinstallprompt). */
    .breathing__install {
      display: inline-flex;
      align-items: center;
      align-self: start;
      gap: var(--space-xs);
      transition:
        background-color var(--motion-quick),
        border-color var(--motion-quick),
        translate var(--motion-quick);
      cursor: pointer;
      margin-block-start: var(--space-md);
      border: 1px solid color-mix(in oklch, var(--breathing-accent) 45%, transparent);
      border-radius: var(--radius-full);
      background: color-mix(in oklch, var(--breathing-accent) 14%, transparent);
      padding: var(--space-xs) var(--space-md);
      color: var(--text-on-dark);
      font-weight: 600;
      font-size: 0.9375rem;
      font-family: var(--font-body);
    }

    @media (hover: hover) and (pointer: fine) {
      .breathing__install:hover {
        translate: 0 -2px;
        border-color: color-mix(in oklch, var(--breathing-accent) 60%, transparent);
        background: color-mix(in oklch, var(--breathing-accent) 22%, transparent);
      }
    }

    .breathing__install:focus-visible {
      outline: 2px solid var(--breathing-accent);
      outline-offset: 3px;
    }

    .breathing__install svg {
      inline-size: 1.1rem;
      block-size: 1.1rem;
    }

    .breathing-app {
      --breathing-cycle-ms: 3600ms;
      display: grid;

      position: relative;
      grid-template-rows: 1fr auto auto auto;
      gap: clamp(var(--space-sm), 3vw, var(--space-md));
      inline-size: 100%;
      max-inline-size: 640px;
      /* Own the full screen height and let the inner 1fr stage absorb any
         shortfall (min-block-size:0 lets it actually shrink). */
      block-size: 100%;
      min-block-size: 0;
      color: var(--text-on-dark);
    }

    .breathing-app__stage {
      display: grid;
      place-items: center;
      min-block-size: 0;
    }

    .breathing-app__circle {
      --size: min(74vw, 46svh, 400px);
      display: grid;

      position: relative;
      place-items: center;
      transition: filter var(--duration-slower) var(--ease-settle);
      cursor: pointer;
      isolation: isolate;
      inline-size: var(--size);
      block-size: var(--size);
      text-align: center;
    }

    .breathing-app[data-phase='breathing'] .breathing-app__circle,
    .breathing-app[data-phase='retention'] .breathing-app__circle,
    .breathing-app[data-phase='recovery'] .breathing-app__circle {
      cursor: default;
    }

    .breathing-app__ring {
      position: absolute;
      transform: scale(var(--ring-scale));
      mix-blend-mode: screen;
      transition:
        --ring-scale var(--duration-slower) var(--ease-settle),
        background var(--duration-slower) var(--ease-settle),
        box-shadow var(--duration-slower) var(--ease-settle);
      will-change: transform;
      box-shadow:
        inset 0 0 50px color-mix(in oklch, var(--breathing-accent) 22%, transparent),
        inset 0 0 2px color-mix(in oklch, var(--breathing-accent) 38%, transparent);
      border-radius: var(--radius-full);
      background: radial-gradient(
        circle at 32% 28%,
        color-mix(in oklch, var(--breathing-accent) 38%, transparent) 0%,
        color-mix(in oklch, var(--breathing-accent-dim) 22%, transparent) 45%,
        color-mix(in oklch, var(--breathing-accent-dim) 8%, transparent) 75%,
        transparent 100%
      );
    }

    .breathing-app__ring--1 {
      opacity: 0.42;
      inset: 0;
    }

    .breathing-app__ring--2 {
      opacity: 0.6;
      inset: 22%;
    }

    .breathing-app__ring--3 {
      opacity: 0.85;
      inset: 42%;
    }

    .breathing-app[data-phase='idle'] .breathing-app__ring--1,
    .breathing-app[data-phase='complete'] .breathing-app__ring--1 {
      animation: breathing-idle 7s var(--ease-precise) infinite;
    }

    .breathing-app[data-phase='idle'] .breathing-app__ring--2,
    .breathing-app[data-phase='complete'] .breathing-app__ring--2 {
      animation: breathing-idle 7s var(--ease-precise) infinite -0.6s;
    }

    .breathing-app[data-phase='idle'] .breathing-app__ring--3,
    .breathing-app[data-phase='complete'] .breathing-app__ring--3 {
      animation: breathing-idle-inner 7s var(--ease-precise) infinite -1.2s;
    }

    .breathing-app__circle[data-motion='wave'] .breathing-app__ring--1 {
      animation: breathing-wave-outer var(--breathing-cycle-ms) var(--ease-precise) infinite;
      transition: none;
    }

    .breathing-app__circle[data-motion='wave'] .breathing-app__ring--2 {
      animation: breathing-wave-mid var(--breathing-cycle-ms) var(--ease-precise) infinite;
      transition: none;
    }

    .breathing-app__circle[data-motion='wave'] .breathing-app__ring--3 {
      animation: breathing-wave-inner var(--breathing-cycle-ms) var(--ease-precise) infinite;
      transition: none;
    }

    .breathing-app__circle[data-motion='hold-high'] .breathing-app__ring--1 {
      --ring-scale: 1.04;
    }

    .breathing-app__circle[data-motion='hold-high'] .breathing-app__ring--2 {
      --ring-scale: 1.3;
    }

    .breathing-app__circle[data-motion='hold-high'] .breathing-app__ring--3 {
      --ring-scale: 1.9;
    }

    .breathing-app__circle[data-motion='hold-low'] .breathing-app__ring--1 {
      --ring-scale: 0.98;
    }

    .breathing-app__circle[data-motion='hold-low'] .breathing-app__ring--2 {
      --ring-scale: 0.95;
    }

    .breathing-app__circle[data-motion='hold-low'] .breathing-app__ring--3 {
      --ring-scale: 0.9;
    }

    .breathing-app__core {
      position: absolute;
      mix-blend-mode: screen;
      transition:
        background var(--duration-slower) var(--ease-settle),
        box-shadow var(--duration-slower) var(--ease-settle);
      inset: 48%;
      box-shadow:
        0 0 60px color-mix(in oklch, var(--breathing-accent) 55%, transparent),
        0 0 120px color-mix(in oklch, var(--breathing-accent) 25%, transparent);
      border-radius: var(--radius-full);
      background: radial-gradient(
        circle at 35% 30%,
        color-mix(in oklch, var(--breathing-accent) 92%, var(--color-bone) 8%),
        color-mix(in oklch, var(--breathing-accent) 70%, transparent) 60%,
        color-mix(in oklch, var(--breathing-accent-dim) 50%, transparent) 100%
      );
    }

    .breathing-app[data-phase='retention'] {
      --breathing-accent: var(--color-sage-light);
      --breathing-accent-dim: var(--color-sage);
    }

    .breathing-app[data-phase='recovery'] {
      --breathing-accent: var(--color-sand-light);
      --breathing-accent-dim: var(--color-sand);
    }

    .breathing-app[data-phase='complete'] {
      --breathing-accent: var(--color-terracotta-light);
      --breathing-accent-dim: var(--color-terracotta);
    }

    .breathing-app__label {
      display: grid;
      position: relative;
      gap: var(--space-2xs);
      z-index: 2;
      padding: var(--space-sm) var(--space-md);
      pointer-events: none;
    }

    .breathing-app__phase {
      display: block;
      color: var(--text-on-dark);
      font-weight: 500;
      font-size: clamp(1.75rem, 6vw, 2.5rem);
      font-family: var(--font-display);
      letter-spacing: 0.01em;
      text-shadow: 0 2px 24px color-mix(in oklch, black 70%, transparent);
    }

    .breathing-app__counter {
      display: block;
      color: color-mix(in oklch, var(--text-on-dark) 70%, transparent);
      font-weight: 500;
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .breathing-app__meta {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-sm);
      text-align: center;
    }

    .breathing-app__meta-item {
      display: grid;
      gap: var(--space-3xs);
      border-block-start: 1px solid color-mix(in oklch, var(--color-sand) 14%, transparent);
      padding-block: var(--space-xs);
    }

    .breathing-app__meta-label {
      color: color-mix(in oklch, var(--text-on-dark) 48%, transparent);
      font-weight: 500;
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .breathing-app__meta-value {
      color: var(--text-on-dark);
      font-weight: 500;
      font-size: clamp(1.125rem, 3vw, 1.375rem);
      font-family: var(--font-display);
      font-variant-numeric: tabular-nums;
    }

    .breathing-app__controls {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: var(--space-xs);
    }

    .breathing-app__controls .btn {
      min-block-size: 52px;
    }

    .breathing-app__start svg {
      margin-inline-start: 3px;
    }

    /* Sound toggle — compact, square ghost icon button. */
    .breathing-app__sound {
      --btn-padding-inline: var(--space-xs);

      aspect-ratio: 1;
    }

    .breathing-app__sound svg {
      inline-size: 1.4rem;
      block-size: 1.4rem;
    }

    .breathing-app__settings {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: var(--space-md) var(--space-lg);
      border-block-start: 1px solid color-mix(in oklch, var(--color-sand) 10%, transparent);
      padding-block-start: var(--space-md);
    }

    .breathing-app__setting {
      display: grid;
      align-content: start;
      justify-items: center;
      gap: var(--space-xs);
      text-align: center;
    }

    .breathing-app__setting--wheel {
      grid-column: 1 / -1;
    }

    .breathing-app__setting-label {
      color: color-mix(in oklch, var(--text-on-dark) 60%, transparent);
      font-weight: 500;
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .breathing-stepper {
      display: inline-grid;
      grid-template-columns: auto minmax(3.5rem, auto) auto;
      align-items: center;
      gap: var(--space-sm);
      border: 1px solid color-mix(in oklch, var(--color-sand) 14%, transparent);
