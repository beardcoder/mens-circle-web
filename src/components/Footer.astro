---
import Logo from './Logo.astro';
import SocialIcon from './SocialIcon.astro';
import site from '../data/site.json';
import nav from '../data/navigation.json';
import type { SocialLink } from '../lib/social';

const socialLinks = site.socialLinks as SocialLink[];
const phoneHref = site.contactPhone
  ? `tel:${site.contactPhone.replace(/[\s\-()]/g, '')}`
  : null;
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <Logo class="footer__logo-icon" />
          <span>{site.siteName}</span>
        </a>
        <p class="footer__text">{site.footerDescription}</p>
        {
          socialLinks.length > 0 && (
            <ul class="footer__social-links">
              {socialLinks.map((link) => (
                <li>
                  <SocialIcon link={link} variant="link" />
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <div class="footer__nav">
        <h3 class="footer__heading">Navigation</h3>
        <ul class="footer__links">
          {
            nav.footerPrimary.map((item) => (
              <li>
                <a
                  href={item.url}
                  data-umami-event="footer-link"
                  data-event-cta={item.url === '/event' ? '' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__contact">
        <h3 class="footer__heading">Kontakt</h3>
        <ul class="footer__links">
          {
            site.contactEmail && (
              <li>
                <a
                  href={`mailto:${site.contactEmail}`}
                  data-umami-event="contact-click"
                  data-umami-event-type="email"
                >
                  E-Mail schreiben
                </a>
              </li>
            )
          }
          {
            phoneHref && (
              <li>
                <a
                  href={phoneHref}
                  data-umami-event="contact-click"
                  data-umami-event-type="phone"
                >
                  {site.contactPhone}
                </a>
              </li>
            )
          }
          {
            nav.footerContact.map((item) => (
              <li>
                <a href={item.url} data-umami-event="footer-link">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">{site.footerText}</p>
      <div class="footer__legal">
        {
          nav.footerLegal.map((item) => (
            <a href={item.url} data-umami-event="footer-link">
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
