---
import nav from '../data/navigation.json';
import site from '../data/site.json';
import type { SocialLink } from '../lib/social';
import Logo from './Logo.astro';
import SocialIcon from './SocialIcon.astro';

const socialLinks = site.socialLinks as SocialLink[];
const phoneHref = site.contactPhone
  ? `tel:${site.contactPhone.replace(/[\s\-()]/g, '')}`
  : null;
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <Logo class="footer__logo-icon" />
          <span>{site.siteName}</span>
        </a>
        <p class="footer__text">{site.footerDescription}</p>
        {
          socialLinks.length > 0 && (
            <ul class="footer__social-links">
              {socialLinks.map((link) => (
                <li>
                  <SocialIcon link={link} variant="link" />
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <div class="footer__nav">
        <h3 class="footer__heading">Navigation</h3>
        <ul class="footer__links">
          {
            nav.footerPrimary.map((item) => (
              <li>
                <a
                  href={item.url}
                  data-umami-event="footer-link"
                  data-event-cta={item.url === '/event' ? '' : undefined}
                  target={'target' in item ? item.target : undefined}
                  rel={
                    'target' in item && item.target === '_blank'
                      ? 'noopener'
                      : undefined
                  }
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__contact">
        <h3 class="footer__heading">Kontakt</h3>
        <ul class="footer__links">
          {
            site.contactEmail && (
              <li>
                <a
                  href={`mailto:${site.contactEmail}`}
                  data-umami-event="contact-click"
                  data-umami-event-type="email"
                >
                  E-Mail schreiben
                </a>
              </li>
            )
          }
          {
            phoneHref && (
              <li>
                <a
                  href={phoneHref}
                  data-umami-event="contact-click"
                  data-umami-event-type="phone"
                >
                  {site.contactPhone}
                </a>
              </li>
            )
          }
          {
            nav.footerContact.map((item) => (
              <li>
                <a href={item.url} data-umami-event="footer-link">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">{site.footerText}</p>
      <div class="footer__legal">
        {
          nav.footerLegal.map((item) => (
            <a href={item.url} data-umami-event="footer-link">
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style is:global>
  @layer components {
    .footer {
      padding-block: var(--space-2xl) var(--space-lg);
      color: var(--text-on-dark);
      background: var(--color-ink);
    }

    .footer__top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--space-xl);
      padding-block-end: var(--space-xl);
      border-block-end: 1px solid var(--border-on-dark);
    }

    @media (width <= 800px) {
      .footer__top {
        grid-template-columns: 1fr;
        gap: var(--space-lg);
      }
    }

    .footer__brand {
      max-inline-size: 380px;
    }

    .footer__logo {
      display: flex;
      gap: var(--space-sm);
      align-items: center;
      margin-block-end: var(--space-md);
      font-family: var(--font-display);
      font-size: var(--text-xl);
      letter-spacing: -0.02em;
    }

    .footer__logo-icon {
      flex-shrink: 0;
      inline-size: 40px;
      block-size: 40px;
      color: var(--accent-secondary);
    }

    .footer__text {
      font-size: 0.9375rem;
      line-height: 1.8;
      color: var(--color-sand);
      opacity: 0.85;
    }

    .footer__social {
      display: flex;
      gap: var(--space-sm);
      margin-block-start: var(--space-lg);
    }

    .footer__social-links {
      display: grid;
      gap: 0.5rem;
      margin-block-start: var(--space-md);
      list-style: none;
    }

    .social-link {
      display: inline-flex;
      gap: 0.75rem;
      align-items: center;
      font-size: 0.9375rem;
      color: var(--color-sand);
      opacity: 0.85;
      transition:
        color var(--motion-quick),
        opacity var(--motion-quick),
        transform var(--motion-quick);
    }

    .social-link:hover {
      color: var(--text-on-dark);
      opacity: 1;
      transform: translateX(2px);
    }

    .social-link__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      inline-size: 20px;
      block-size: 20px;
    }

    .social-link__icon svg {
      inline-size: 100%;
      block-size: 100%;
    }

    .social-link__label {
      line-height: 1.4;
    }

    .footer__heading {
      margin-block-end: var(--space-md);
      font-family: var(--font-body);
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--accent-secondary);
      text-transform: uppercase;
      letter-spacing: 0.25em;
    }

    .footer__links {
      list-style: none;
    }

    .footer__links li {
      margin-block-end: 0.625rem;
    }

    .footer__links a {
      position: relative;
      display: inline-block;
      padding-inline-start: 0;
      font-size: 0.9375rem;
      color: var(--color-sand);
      opacity: 0.85;
      transition:
        color 380ms var(--ease-settle),
        opacity 380ms var(--ease-settle),
        padding-inline-start 420ms var(--ease-settle);
    }

    .footer__links a::before {
      position: absolute;
      inset-block-start: 50%;
      inset-inline-start: 0;
      inline-size: 0;
      block-size: 1px;
      pointer-events: none;
      content: '';
      background: var(--accent-secondary);
      opacity: 0;
      transform: translateY(-50%);
      transition:
        inline-size 420ms var(--ease-settle),
        opacity 380ms var(--ease-settle);
    }

    .footer__legal a {
      position: relative;
      font-size: 0.8125rem;
      color: var(--color-sand);
      opacity: 0.9;
      transition:
        color 380ms var(--ease-settle),
        opacity var(--motion-quick);
    }

    .footer__legal a::after {
      position: absolute;
      inset-block-end: -2px;
      inset-inline: 0;
      block-size: 1px;
      pointer-events: none;
      content: '';
      background: var(--accent-secondary);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 380ms var(--ease-settle);
    }

    @media (hover: hover) and (pointer: fine) {
      .footer__links a:hover,
      .footer__links a:focus-visible {
        padding-inline-start: 18px;
        color: var(--accent-secondary);
        opacity: 1;
      }

      .footer__links a:hover::before,
      .footer__links a:focus-visible::before {
        inline-size: 12px;
        opacity: 1;
      }

      .footer__legal a:hover,
      .footer__legal a:focus-visible {
        color: var(--accent-secondary);
        opacity: 1;
      }

      .footer__legal a:hover::after,
      .footer__legal a:focus-visible::after {
        transform: scaleX(1);
      }
    }

    .footer__bottom {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-sm);
      align-items: center;
      justify-content: space-between;
      padding-block-start: var(--space-lg);
    }

    @media (width <= 800px) {
      .footer__bottom {
        flex-direction: column;
        text-align: center;
      }
    }

    .footer__copyright {
      font-size: 0.8125rem;
      color: var(--color-sand);
      opacity: 0.9;
    }

    .footer__legal {
      display: flex;
      gap: var(--space-md);
    }
  }
</style>
