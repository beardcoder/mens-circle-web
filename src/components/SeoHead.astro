---
import site from '../data/site.json';

// Font preloading is handled by the native <Font preload /> component in the
// layout head (fonts configured in astro.config.mjs).

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogType?: string;
  /** Open Graph / social title. Falls back to `title` (then the site name). */
  ogTitle?: string;
  /** Open Graph / social description. Falls back to `description`. */
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  robots?: string;
  /** Extra JSON-LD objects to embed (HowTo, FAQPage, Event, …). */
  schemas?: Record<string, unknown>[];
  /** Web app manifest to link. Defaults to the site-wide manifest; a page can
   *  point at a focused one (e.g. the installable breathing app). */
  manifest?: string;
  /** When set, the page advertises itself as an installable standalone web app
   *  (adds the iOS/Android web-app metas with this as the home-screen title). */
  webAppTitle?: string;
  /** Viewport meta content. Defaults to a zoomable viewport with
   *  `viewport-fit=cover` so `env(safe-area-inset-*)` actually resolves; an
   *  app-like page can override it (e.g. to lock zoom). */
  viewport?: string;
}

const {
  title,
  description = 'Authentischer Austausch, Gemeinschaft und persönliches Wachstum für Männer in Niederbayern.',
  keywords = 'Männerkreis, Niederbayern, Männergruppe, persönliches Wachstum, Gemeinschaft, Männer',
  ogType = 'website',
  ogTitle,
  ogDescription,
  ogImage,
  ogImageAlt = 'Männerkreis Niederbayern/ Straubing - Gemeinschaft für Männer',
  robots = 'index, follow',
  schemas = [],
  manifest = '/manifest.webmanifest',
  webAppTitle,
  viewport = 'width=device-width, initial-scale=1.0, viewport-fit=cover',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://mens-circle.de');
const canonical = new URL(Astro.url.pathname, siteUrl).href;

// Only third-party origin we ever load: the Umami analytics endpoint (when
// configured). Preconnect to it so the tracker script connects faster.
// Everything else (fonts, CSS, JS, API) is same-origin, so no other
// preconnect candidates exist.
const umamiId = import.meta.env.PUBLIC_UMAMI_ID;
const umamiOrigin = umamiId
  ? (() => {
      try {
        return new URL(import.meta.env.PUBLIC_UMAMI_ENDPOINT || 'https://cloud.umami.is').origin;
      } catch {
        return null;
      }
    })()
  : null;
const fullTitle = title ?? `${site.siteName}${site.tagline ? ` – ${site.tagline}` : ''}`;
const socialTitle = ogTitle ?? title ?? site.siteName;
const socialDescription = ogDescription ?? description;
const ogImageUrl = new URL(ogImage ?? '/images/logo-color.png', siteUrl).href;

// Global structured data (mirrors the original LocalBusiness/Organization/WebSite).
const sameAs = site.socialLinks.filter((l) => !['email', 'phone', 'whatsapp'].includes(l.type)).map((l) => l.value);

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteUrl.origin}/#organization`,
  name: 'Männerkreis Niederbayern/ Straubing',
  description: site.description,
  url: siteUrl.origin,
  logo: new URL('/images/logo-color.png', siteUrl).href,
  image: new URL('/images/logo-color.png', siteUrl).href,
  email: site.contactEmail,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.geo.locality,
    addressRegion: site.geo.region,
    postalCode: site.geo.postalCode,
    addressCountry: site.geo.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.lat,
    longitude: site.geo.lng,
  },
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: {
      '@type': 'GeoCoordinates',
      latitude: site.geo.lat,
      longitude: site.geo.lng,
    },
    geoRadius: 50000,
  },
  priceRange: '€',
  ...(sameAs.length ? { sameAs } : {}),
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl.origin}/#website`,
  name: site.siteName,
  url: siteUrl.origin,
  description: site.description,
  inLanguage: 'de-DE',
  publisher: { '@id': `${siteUrl.origin}/#organization` },
};

const allSchemas = [localBusiness, website, ...schemas];
---

<meta name="viewport" content={viewport} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content="Markus Sommer" />
<link rel="canonical" href={canonical} />

<link rel="alternate" hreflang="de" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<meta name="theme-color" content={site.themeColor} />
<meta name="color-scheme" content="light" />
<meta name="msapplication-TileColor" content={site.themeColor} />

{umamiOrigin && <link rel="preconnect" href={umamiOrigin} crossorigin />}

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={socialDescription} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content="de_DE" />
<meta property="og:site_name" content={site.siteName} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={socialDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<!-- Robots -->
<meta name="robots" content={robots} />
<meta name="googlebot" content={robots} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon-180x180.png" />
<link rel="manifest" href={manifest} />

{
  /* Installable standalone web app (e.g. the breathing exercise). */
  webAppTitle && (
    <>
      <meta name="mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
      <meta name="apple-mobile-web-app-title" content={webAppTitle} />
    </>
  )
}

<!-- Structured data -->
{allSchemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
