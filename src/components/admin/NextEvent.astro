---
import CapacityRing from './CapacityRing.astro';

type Status = 'registered' | 'waitlist' | 'cancelled' | 'attended';
interface Person {
  firstName: string;
  lastName: string;
  status: Status;
}
interface NextEventData {
  id: string;
  title: string;
  eventDate: string;
  startTime?: string;
  endTime?: string;
  location?: string;
  maxParticipants: number;
  activeCount: number;
}
interface Props {
  event: NextEventData;
  people: Person[];
}
const { event, people } = Astro.props;

const registered = people.filter((p) => p.status === 'registered' || p.status === 'attended');
const waitlist = people.filter((p) => p.status === 'waitlist');

const dateLong = (() => {
  const d = new Date(event.eventDate);
  if (Number.isNaN(d.getTime())) return event.eventDate;
  return d.toLocaleDateString('de-DE', {
    weekday: 'long',
    day: '2-digit',
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });
})();
const timeStr = event.startTime ? `${event.startTime}${event.endTime ? `–${event.endTime}` : ''} Uhr` : '';
const name = (p: Person) => `${p.firstName} ${p.lastName}`.trim();
---

<section class="next">
  <div class="next__bar">
    <p class="eyebrow">Nächstes Event · Planung</p>
    <a class="btn btn--sm" href={`/admin/events/${event.id}/registrations`}>Anmeldungen verwalten</a>
  </div>

  <div class="next__head">
    <CapacityRing value={event.activeCount} max={event.maxParticipants} size={68} stroke={6} />
    <div class="next__titles">
      <a class="next__title" href={`/admin/events/${event.id}`}>{event.title}</a>
      <p class="next__meta mono">
        {dateLong}
        {timeStr && <span> · {timeStr}</span>}
        {event.location && <span class="faint"> · {event.location}</span>}
      </p>
    </div>
  </div>

  <div class="next__roster">
    <div class="roster__col">
      <p class="roster__label">
        Angemeldet <span class="mono roster__n">{registered.length}/{event.maxParticipants}</span>
      </p>
      {
        registered.length === 0 ? (
          <p class="muted roster__empty">Noch niemand angemeldet.</p>
        ) : (
          <ol class="roster">
            {registered.map((p, i) => (
              <li class="roster__person">
                <span class="roster__idx mono faint">{String(i + 1).padStart(2, '0')}</span>
                <span class="roster__name">{name(p)}</span>
                {p.status === 'attended' && <span class="badge badge--live">da</span>}
              </li>
            ))}
          </ol>
        )
      }
    </div>

    {
      waitlist.length > 0 && (
        <div class="roster__col">
          <p class="roster__label">
            Warteliste <span class="mono roster__n">{waitlist.length}</span>
          </p>
          <ol class="roster">
            {waitlist.map((p, i) => (
              <li class="roster__person">
                <span class="roster__idx mono faint">{String(i + 1).padStart(2, '0')}</span>
                <span class="roster__name muted">{name(p)}</span>
              </li>
            ))}
          </ol>
        </div>
      )
    }
  </div>
</section>

<style>
  .next {
    background: linear-gradient(180deg, var(--ember-soft), transparent 40%), var(--surface);
    border: 1px solid var(--ember-line);
    border-radius: var(--r);
    padding: clamp(1.1rem, 3vw, 1.6rem);
    margin-bottom: 2.25rem;
  }
  .next__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .next__head {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .next__titles {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  .next__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.2rem, 1rem + 1vw, 1.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text);
    text-decoration: none;
  }
  .next__title:hover {
    color: var(--ember-bright);
  }
  .next__meta {
    margin: 0;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .next__roster {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem 2rem;
    padding-top: 1.1rem;
  }
  .roster__label {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.6rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .roster__n {
    color: var(--ember);
    font-weight: 600;
    letter-spacing: 0;
  }
  .roster__empty {
    font-size: 0.85rem;
    margin: 0;
  }
  .roster {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .roster__person {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--line);
  }
  .roster__person:last-child {
    border-bottom: none;
  }
  .roster__idx {
    font-size: 0.72rem;
  }
  .roster__name {
    font-size: 0.92rem;
  }
  .roster__person .badge {
    margin-left: auto;
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
  }
</style>
