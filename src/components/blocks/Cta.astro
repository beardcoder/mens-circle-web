---
interface Props {
  data: {
    anchor?: string;
    eyebrow?: string;
    title?: string;
    text?: string;
    buttonText?: string;
    buttonLink?: string;
  };
}

const { data } = Astro.props;
---

<section
  class="section section--large cta-section"
  id={data.anchor}
>
  <div
    class="cta__ornament cta__ornament--outer"
    aria-hidden="true"
  >
  </div>
  <div
    class="cta__ornament cta__ornament--inner"
    aria-hidden="true"
  >
  </div>
  <div class="container">
    <div
      class="cta__content"
      data-reveal-group="100"
    >
      {
        data.eyebrow && (
          <p
            class="eyebrow"
            data-reveal="up"
          >
            {data.eyebrow}
          </p>
        )
      }

      {
        data.title && (
          <h2
            class="section-title cta__title"
            data-reveal="blur"
            set:html={data.title}
          />
        )
      }

      {
        data.text && (
          <p
            class="cta__text"
            data-reveal="up"
          >
            {data.text}
          </p>
        )
      }

      {
        data.buttonText && data.buttonLink && (
          <a
            href={data.buttonLink}
            class="btn btn--primary btn--large"
            data-reveal="up"
            data-event-cta={
              data.buttonLink?.startsWith('/event') ? '' : undefined
            }
            data-umami-event="cta-click"
            data-umami-event-location="cta-block"
            data-umami-event-text={data.buttonText}
          >
            {data.buttonText}
          </a>
        )
      }
    </div>
  </div>
</section>

<style is:global>
  @layer sections {
    .cta-section {
      position: relative;
      overflow: clip;
      text-align: center;
      background: var(--bg-tertiary);
    }

    .cta__ornament {
      position: absolute;
      inset-block-start: 50%;
      inset-inline-start: 50%;
      pointer-events: none;
      border: 1px solid var(--color-sand);
      border-radius: 50%;
      transform: translate(-50%, -50%);
    }

    .cta__ornament--outer {
      inline-size: 50vw;
      block-size: 50vw;
      opacity: 0.3;
      animation: breathe-slow 24s var(--ease-ambient) infinite;
    }

    .cta__ornament--inner {
      inline-size: 35vw;
      block-size: 35vw;
      opacity: 0.2;
      animation: breathe 20s var(--ease-ambient) infinite -8s;
    }

    .cta__content {
      position: relative;
      z-index: 1;
      max-inline-size: var(--content-max-wide);
      margin-inline: auto;
    }

    .cta__text {
      margin-block-end: var(--rhythm-block);
      font-size: var(--text-section-body-lg);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
    }
  }
</style>
