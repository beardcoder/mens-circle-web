---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Sprite from '../Sprite.astro';

interface Props {
  data: {
    anchor?: string;
    eyebrow?: string;
    name?: string;
    bio?: string;
    quote?: string;
    photo?: string;
  };
}

const { data } = Astro.props;
const anchor = data.anchor ?? 'moderator';
// Derive a meaningful alt from the (HTML) name for the portrait.
const photoAlt = data.name
  ? data.name
      .replace(/<[^>]*>/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
  : 'Begleiter';

// Resolve the photo path (e.g. "/images/foo.jpg") to an imported asset so
// Astro can generate optimised, responsive output at build time.
const assetImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);
const photoKey = data.photo
  ? `/src/assets/images/${data.photo.replace(/^\/images\//, '')}`
  : null;
const photoAsset = photoKey ? (assetImages[photoKey]?.default ?? null) : null;
---

<section class="section moderator-section" id={anchor}>
  <span class="moderator__ornament" aria-hidden="true">BEGLEITER</span>
  <div class="container">
    <div class="moderator__layout">
      <div class="moderator__photo-wrapper" data-reveal="right">
        <div class="moderator__photo" data-motion="image">
          {
            photoAsset ? (
              <Picture
                src={photoAsset}
                alt={photoAlt}
                widths={[400, 700, 900, 1000]}
                sizes="(max-width: 900px) min(350px, 85vw), 55vw"
                formats={['avif', 'webp']}
                loading="lazy"
                decoding="async"
              />
            ) : data.photo ? (
              <img
                src={data.photo}
                loading="lazy"
                decoding="async"
                alt={photoAlt}
              />
            ) : (
              <div class="moderator__photo-placeholder">
                <Sprite name="user" />
                <span>Foto</span>
              </div>
            )
          }
        </div>
        <div class="moderator__photo-accent"></div>
      </div>

      <div class="moderator__content" data-reveal-group="100">
        {
          data.eyebrow && (
            <p class="eyebrow" data-reveal="up">
              {data.eyebrow}
            </p>
          )
        }

        {
          data.name && (
            <h2
              class="moderator__name"
              data-reveal="blur"
              set:html={data.name}
            />
          )
        }

        {
          data.bio && (
            <div class="moderator__bio" data-reveal="up" set:html={data.bio} />
          )
        }

        {
          data.quote && (
            <blockquote class="moderator__quote" data-reveal="up">
              <p>{data.quote}</p>
            </blockquote>
          )
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  @layer sections {
    .moderator-section {
      position: relative;
      overflow: clip;
      background: var(--bg-tertiary);
    }

    .moderator__ornament {
      position: absolute;
      inset-block-start: 50%;
      inset-inline-start: -5%;
      font-family: var(--font-display);
      font-size: clamp(4rem, 12vw, 10rem);
      color: var(--border-light);
      letter-spacing: 0.1em;
      white-space: nowrap;
      pointer-events: none;
      user-select: none;
      opacity: 0.5;
      transform: translateY(-50%) rotate(-90deg);
    }

    @media (width <= 900px) {
      .moderator__ornament {
        display: none;
      }
    }

    /* The vertical background word drifts slowly across as the section scrolls
       by, so the otherwise-static ornament breathes with the page. Animates
       `translate` (not `transform`) to keep the rotate/centring intact. */
    @media (prefers-reduced-motion: no-preference) {
      @supports (animation-timeline: view()) {
        .moderator-section {
          view-timeline: --moderator-panel block;
        }

        .moderator__ornament {
          animation: moderator-word-drift linear both;
          animation-timeline: --moderator-panel;
        }
      }
    }

    .moderator__layout {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-xl);
      align-items: center;
      min-block-size: 90vh;
      padding-block: var(--space-xl);
    }

    @media (width <= 900px) {
      .moderator__layout {
        grid-template-columns: 1fr;
        gap: var(--space-lg);
        min-block-size: auto;
      }
    }

    .moderator__photo-wrapper {
      position: relative;
    }

    @media (prefers-reduced-motion: no-preference) {
      .moderator__photo-wrapper {
        animation: float 7s var(--ease-ambient) infinite;
      }
    }

    @media (width <= 900px) {
      .moderator__photo-wrapper {
        max-inline-size: 350px;
        margin-inline: auto;
      }
    }

    .moderator__photo {
      --_surface-noise-opacity: 0.04;

      position: relative;
      background: var(--bg-section-alt);
    }

    .moderator__photo picture {
      display: block;
      inline-size: 100%;
      block-size: 100%;
    }

    .moderator__photo-placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      align-items: center;
      justify-content: center;
      color: var(--text-on-dark);
    }

    .moderator__photo-placeholder svg {
      inline-size: 80px;
      block-size: 80px;
      opacity: 0.3;
      fill: none;
      stroke: currentcolor;
      stroke-width: 0.5;
    }

    .moderator__photo-placeholder span {
      margin-inline: -0.05em 0.08em;
      font-style: italic;
      opacity: 0.5;
    }

    .moderator__photo-accent {
      position: absolute;
      inset-block: var(--space-md) calc(var(--space-md) * -1);
      inset-inline: var(--space-md) calc(var(--space-md) * -1);
      z-index: -1;
      border: 1px solid var(--accent-primary);
      opacity: 0.5;
    }

    .moderator__content {
      position: relative;
      padding-inline-start: var(--space-lg);
    }

    @media (width <= 900px) {
      .moderator__content {
        padding-inline-start: 0;
      }
    }

    .moderator__name {
      margin-block-end: var(--space-md);
      font-size: clamp(3.5rem, 7vw, 6.5rem);
      line-height: 0.93;
    }

    .moderator__name .light {
      display: block;
      font-weight: 300;
      letter-spacing: 0.02em;
    }

    .moderator__bio {
      max-inline-size: var(--content-max-text);
      margin-block-end: var(--space-md);
      font-size: var(--text-section-body);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
    }

    .moderator__quote {
      max-inline-size: var(--content-max-text);
      padding-inline-start: var(--space-md);
      margin-block-start: var(--space-lg);
      border-inline-start: 3px solid var(--accent-primary);
    }

    .moderator__quote p {
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 3vw, 2.75rem);
      font-style: italic;
      line-height: 1.3;
      color: var(--text-accent);
      letter-spacing: -0.025em;
    }
  }
</style>
