---
// Testimonials are rendered server-side: this block is a server island on the
// (prerendered) home page, so published entries are fetched from the database
// per request and rendered into the HTML — great SEO, no client fetch / loading
// flash, and new testimonials go live with no rebuild.
//
// The section renders nothing when there are no published testimonials.
//
// The data layer (`@lib/server/events` → `bun:sqlite`) is imported dynamically:
// this runs only when the island renders at runtime, never during the
// build-time prerender of the host page.
interface Props {
  data?: { anchor?: string };
}

const { data } = Astro.props;
const anchor = data?.anchor ?? 'stimmen';
const { fetchTestimonials } = await import('@lib/server/events');
const testimonials = await fetchTestimonials();

// Editorial hierarchy: the first (highest-sorted) testimonial becomes a large
// featured statement; the remaining voices sit in the grid below it.
const [featured, ...rest] = testimonials;
---

{
  testimonials.length > 0 && (
    <section class="section section--large testimonials-section" id={anchor} aria-labelledby="testimonials-title">
      <div class="testimonials__pattern" aria-hidden="true" />
      <div class="container">
        <div class="section-header section-header--on-dark section-header--start">
          <p class="eyebrow eyebrow--secondary">Echte Stimmen</p>
          <h2 class="section-title section-title--lg" id="testimonials-title">
            Worte aus dem <span class="highlight">Kreis</span>
          </h2>
          <p class="testimonials__subtitle">Keine Versprechen. Nur das, was Männer hier wirklich erlebt haben.</p>
        </div>

        {featured && (
          <figure class="testimonials__featured">
            <blockquote class="testimonials__featured-quote">{featured.quote}</blockquote>
            {(featured.author || featured.role) && (
              <figcaption class="testimonials__featured-author">
                {featured.author && <cite class="testimonial-item__name">{featured.author}</cite>}
                {featured.role && <span class="testimonial-item__role">{featured.role}</span>}
              </figcaption>
            )}
          </figure>
        )}

        {rest.length > 0 && (
          <div class="testimonials__grid">
            {rest.map((t) => (
              <article class="testimonial-item">
                <blockquote class="testimonial-item__quote">{t.quote}</blockquote>
                {(t.author || t.role) && (
                  <div class="testimonial-item__author">
                    {t.author && <cite class="testimonial-item__name">{t.author}</cite>}
                    {t.role && <span class="testimonial-item__role">{t.role}</span>}
                  </div>
                )}
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  )
}

<style is:global>
  @layer sections {
    .testimonials-section {
      --_surface-noise-opacity: 0.04;

      position: relative;
      overflow: clip;
      color: var(--text-on-dark);
      background: var(--bg-dark);
    }

    /* Soft terracotta glow rising from the lower edge — gives the dark panel
       depth and makes the quotes feel lit from within, mirroring the Journey
       section's treatment. */
    .testimonials__pattern {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(
        ellipse 70% 55% at 50% 110%,
        color-mix(in oklch, var(--accent-primary) 18%, transparent) 0%,
        transparent 55%
      );
    }

    .testimonials__subtitle {
      max-inline-size: 52ch;
      margin-block: 0;
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-style: italic;
      line-height: var(--leading-normal);
      color: var(--text-on-dark-secondary);
    }

    .testimonials-section .section-title .highlight {
      color: var(--accent-secondary);
    }

    /* ── Featured statement — the plakativ centrepiece ──
       One oversized leading quote, set as a poster headline with a huge
       quotation mark bleeding off the top-left. Sets the tone before the
       supporting voices in the grid below. */
    .testimonials__featured {
      position: relative;
      z-index: 1;
      max-inline-size: min(100%, 54rem);
      margin: 0;
      margin-block-end: var(--space-xl);
      padding-block-start: clamp(3rem, 7vw, 6rem);
    }

    .testimonials__featured::before {
      position: absolute;
      inset-block-start: clamp(-0.5rem, 1vw, 1rem);
      inset-inline-start: -0.06em;
      font-family: var(--font-display);
      font-size: clamp(7rem, 16vw, 13rem);
      line-height: 0.6;
      color: color-mix(in oklch, var(--accent-secondary) 26%, transparent);
      content: '\201E';
    }

    /* The measure lives on the quote itself so `ch` resolves against the large
       display size — not the figure's inherited body font (which would collapse
       it into a narrow tower). */
    .testimonials__featured-quote {
      max-inline-size: 21ch;
      margin: 0;
      font-family: var(--font-display);
      font-size: clamp(1.9rem, 1.1rem + 3vw, 3.25rem);
      font-style: italic;
      line-height: 1.12;
      color: var(--color-sand-light);
      letter-spacing: -0.015em;
      text-wrap: balance;
    }

    .testimonials__featured-author {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs) var(--space-sm);
      align-items: baseline;
      margin-block-start: var(--space-md);
    }

    /* Dark-surface dividers: override the light grid borders that the shared
       surface rules apply (grid frame + every cell separator, incl. the mobile
       and nth-child variants), so the cells read on the dark panel. */
    .testimonials-section .testimonials__grid,
    .testimonials-section .testimonial-item {
      border-color: var(--border-on-dark);
    }

    .testimonial-item {
      position: relative;
      display: flex;
      flex-direction: column;
      min-block-size: 16rem;
      padding: var(--space-lg) var(--space-md);
      border-inline-start: 1px solid var(--border-on-dark);
    }

    /* Plakativ: the quote is the hero of the card — large display serif,
       lit warm, with an oversized opening quotation mark. */
    .testimonial-item__quote {
      position: relative;
      flex-grow: 1;
      padding-block-start: clamp(2rem, 4vw, 3rem);
      margin: 0;
      margin-block-end: var(--space-lg);
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 0.95rem + 1.1vw, 1.6rem);
      font-style: italic;
      line-height: 1.35;
      color: var(--color-sand-light);
      text-wrap: balance;
    }

    .testimonial-item__quote::before {
      position: absolute;
      inset-block-start: -0.6rem;
      inset-inline-start: -0.5rem;
      font-family: var(--font-display);
      font-size: clamp(4.5rem, 9vw, 7rem);
      line-height: 1;
      color: color-mix(in oklch, var(--accent-secondary) 32%, transparent);
      content: '\201E';
    }

    .testimonial-item__author {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
      padding-block-start: var(--space-md);
      border-block-start: 1px solid var(--border-on-dark);
    }

    .testimonial-item__name {
      font-size: var(--text-body-compact);
      font-style: normal;
      font-weight: 600;
      letter-spacing: 0.01em;
      color: var(--text-on-dark);
    }

    .testimonial-item__role {
      font-size: var(--text-caption);
      color: var(--accent-secondary);
    }
  }
</style>
