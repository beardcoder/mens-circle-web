---
// Testimonials are dynamic: published entries are fetched from PocketBase at
// runtime by the island (the section hides itself when there are none).
import TestimonialsList from '../islands/TestimonialsList.svelte';

interface Props {
  data?: { anchor?: string };
}

const { data } = Astro.props;
---

<!-- client:idle (not client:visible): the island renders nothing until its
     PocketBase fetch resolves, so a visibility observer would have no sized
     target to trigger on. idle hydration guarantees it loads. -->
<TestimonialsList client:idle anchor={data?.anchor ?? 'stimmen'} />
