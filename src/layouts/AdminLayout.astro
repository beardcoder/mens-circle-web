---
/**
 * Standalone, lightweight layout for the admin area. Deliberately separate from
 * the public site shell (no marketing header/footer/fonts) — a focused, fast
 * back-office. Auth is enforced by the middleware; `Astro.locals.admin` is set.
 */
interface Props {
  title: string;
  /** Hide the nav (used by the login page). */
  bare?: boolean;
}
const { title, bare = false } = Astro.props;
const admin = Astro.locals.admin;
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Admin · Männerkreis</title>
  </head>
  <body>
    {
      !bare && (
        <header class="admin-topbar">
          <nav class="admin-nav">
            <a href="/admin" class="admin-brand">Männerkreis Admin</a>
            <a href="/admin">Veranstaltungen</a>
            <a href="/admin/testimonials">Stimmen</a>
          </nav>
          <div class="admin-user">
            {admin && <span>{admin}</span>}
            <button type="button" id="admin-logout" class="admin-btn admin-btn--ghost">Abmelden</button>
          </div>
        </header>
      )
    }
    <main class="admin-main">
      <slot />
    </main>

    {
      !bare && (
        <script is:inline>
          document.getElementById('admin-logout')?.addEventListener('click', async () => {
            await fetch('/api/admin/logout', { method: 'POST' });
            window.location.href = '/admin/login';
          });
        </script>
      )
    }

    <style is:global>
      :root {
        --a-bg: #f5f2ec;
        --a-surface: #ffffff;
        --a-border: #e3dccb;
        --a-text: #2c2418;
        --a-muted: #7a6248;
        --a-accent: #b86f52;
        --a-accent-ink: #ffffff;
        --a-danger: #b03a2e;
        --a-ok: #3a7d44;
        --a-radius: 8px;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family:
          'DM Sans',
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          sans-serif;
        background: var(--a-bg);
        color: var(--a-text);
        line-height: 1.5;
      }
      .admin-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 0.75rem 1.5rem;
        background: var(--a-surface);
        border-bottom: 1px solid var(--a-border);
      }
      .admin-nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
      }
      .admin-nav a {
        color: var(--a-muted);
        text-decoration: none;
        font-size: 0.95rem;
      }
      .admin-nav a:hover {
        color: var(--a-text);
      }
      .admin-brand {
        font-weight: 700;
        color: var(--a-text) !important;
        font-size: 1.05rem;
      }
      .admin-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.9rem;
        color: var(--a-muted);
      }
      .admin-main {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }
      h1 {
        font-size: 1.6rem;
        margin: 0 0 1rem;
      }
      h2 {
        font-size: 1.2rem;
        margin: 2rem 0 0.75rem;
      }
      a {
        color: var(--a-accent);
      }
      .admin-card {
        background: var(--a-surface);
        border: 1px solid var(--a-border);
        border-radius: var(--a-radius);
        padding: 1.25rem;
      }
      .admin-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border: 1px solid var(--a-accent);
        background: var(--a-accent);
        color: var(--a-accent-ink);
        font: inherit;
        font-size: 0.9rem;
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        cursor: pointer;
        text-decoration: none;
      }
      .admin-btn:hover {
        filter: brightness(0.95);
      }
      .admin-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
      .admin-btn--ghost {
        background: transparent;
        color: var(--a-muted);
        border-color: var(--a-border);
      }
      .admin-btn--danger {
        background: transparent;
        color: var(--a-danger);
        border-color: var(--a-danger);
      }
      .admin-btn--small {
        font-size: 0.8rem;
        padding: 0.3rem 0.6rem;
      }
      label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--a-muted);
        margin-bottom: 0.3rem;
      }
      input[type='text'],
      input[type='email'],
      input[type='password'],
      input[type='number'],
      input[type='date'],
      input[type='time'],
      input[type='url'],
      textarea,
      select {
        width: 100%;
        font: inherit;
        padding: 0.55rem 0.7rem;
        border: 1px solid var(--a-border);
        border-radius: 6px;
        background: #fff;
        color: var(--a-text);
      }
      textarea {
        min-height: 6rem;
        resize: vertical;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      th,
      td {
        text-align: left;
        padding: 0.6rem 0.5rem;
        border-bottom: 1px solid var(--a-border);
        vertical-align: middle;
      }
      th {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--a-muted);
      }
      .admin-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        background: var(--a-border);
        color: var(--a-text);
      }
      .admin-badge--ok {
        background: #d8ecd8;
        color: var(--a-ok);
      }
      .admin-badge--wait {
        background: #f7e6cf;
        color: #9a6516;
      }
      .admin-badge--off {
        background: #eee;
        color: #888;
      }
      .admin-muted {
        color: var(--a-muted);
      }
      .admin-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .admin-row > * {
        flex: 1 1 0;
        min-width: 160px;
      }
      .admin-toast {
        margin-bottom: 1rem;
        padding: 0.7rem 1rem;
        border-radius: 6px;
        font-size: 0.9rem;
      }
      .admin-toast--ok {
        background: #d8ecd8;
        color: var(--a-ok);
      }
      .admin-toast--err {
        background: #f6d8d4;
        color: var(--a-danger);
      }
    </style>
  </body>
</html>
