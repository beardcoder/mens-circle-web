---
/**
 * Minimal, self-contained admin layout. Deliberately tiny (no fonts API, no
 * analytics, inline CSS) so the admin adds ~0 weight to the public site.
 */
interface Props {
  title: string;
  active?: 'dashboard' | 'events' | 'testimonials';
}
const { title, active } = Astro.props;
const admin = Astro.locals.admin;
const nav: Array<{ href: string; label: string; key: Props['active'] }> = [
  { href: '/admin', label: 'Übersicht', key: 'dashboard' },
  { href: '/admin/events', label: 'Events', key: 'events' },
  { href: '/admin/testimonials', label: 'Testimonials', key: 'testimonials' },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · Admin</title>
    <style>
      :root {
        --bg: #f4f0e8; --panel: #fff; --ink: #2c2418; --muted: #7a6248;
        --line: #e3dccb; --accent: #b86f52; --accent-ink: #fff;
        --ok: #2f7d4f; --warn: #b8893f; --danger: #b3402f;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--ink);
        font: 15px/1.55 system-ui, -apple-system, 'Segoe UI', sans-serif;
      }
      header {
        display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;
        background: var(--panel); border-bottom: 1px solid var(--line);
        padding: 0.75rem 1.25rem;
      }
      header .brand { font-weight: 700; }
      nav { display: flex; gap: 0.25rem; }
      nav a {
        text-decoration: none; color: var(--muted); padding: 0.35rem 0.7rem;
        border-radius: 6px;
      }
      nav a.active, nav a:hover { background: var(--bg); color: var(--ink); }
      header .right { margin-left: auto; display: flex; align-items: center; gap: 0.75rem; color: var(--muted); font-size: 0.85rem; }
      main { max-width: 960px; margin: 0 auto; padding: 1.5rem 1.25rem 4rem; }
      h1 { font-size: 1.5rem; margin: 0 0 1rem; }
      h2 { font-size: 1.15rem; margin: 2rem 0 0.75rem; }
      .panel { background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 1.25rem; margin-bottom: 1.25rem; }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: left; padding: 0.55rem 0.5rem; border-bottom: 1px solid var(--line); vertical-align: top; }
      th { color: var(--muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
      a { color: var(--accent); }
      label { display: block; font-size: 0.8rem; color: var(--muted); margin: 0.75rem 0 0.25rem; }
      input[type='text'], input[type='email'], input[type='password'], input[type='number'], input[type='datetime-local'], input[type='time'], textarea, select {
        width: 100%; padding: 0.5rem 0.6rem; border: 1px solid var(--line); border-radius: 6px;
        font: inherit; background: #fff; color: var(--ink);
      }
      textarea { min-height: 6rem; resize: vertical; }
      .row { display: grid; grid-template-columns: 1fr 1fr; gap: 0 1rem; }
      .check { display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem; }
      .check input { width: auto; }
      .check label { margin: 0; }
      .btn {
        display: inline-block; border: 0; border-radius: 6px; cursor: pointer;
        background: var(--accent); color: var(--accent-ink); padding: 0.55rem 1rem;
        font: inherit; font-weight: 600; text-decoration: none;
      }
      .btn.secondary { background: var(--bg); color: var(--ink); border: 1px solid var(--line); }
      .btn.danger { background: var(--danger); }
      .btn.small { padding: 0.3rem 0.6rem; font-size: 0.85rem; }
      .actions { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
      .badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
      .badge.green { background: #e3f1e8; color: var(--ok); }
      .badge.amber { background: #f6ecd9; color: var(--warn); }
      .badge.grey { background: #ece7db; color: var(--muted); }
      .badge.red { background: #f6e0db; color: var(--danger); }
      .muted { color: var(--muted); }
      form.inline { display: inline; }
      .grid-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
      .card-num { font-size: 2rem; font-weight: 700; }
    </style>
  </head>
  <body>
    {admin && (
      <header>
        <span class="brand">Männerkreis · Admin</span>
        <nav>
          {nav.map((n) => (
            <a href={n.href} class={active === n.key ? 'active' : ''}>{n.label}</a>
          ))}
        </nav>
        <span class="right">
          <span>{admin}</span>
          <form method="post" action="/api/admin/logout" class="inline">
            <button class="btn secondary small" type="submit">Abmelden</button>
          </form>
        </span>
      </header>
    )}
    <main>
      <slot />
    </main>
  </body>
</html>
