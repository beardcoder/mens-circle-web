---
/**
 * Admin shell — "Dusk Circle". A standalone, dark back-office, deliberately
 * separate from the public marketing shell. Identity: a sturdy grotesque
 * display (Bricolage), a logbook mono for all data (IBM Plex Mono), an ember
 * accent, and the filling-ring capacity motif. Auth is enforced by middleware;
 * `Astro.locals.admin` holds the operator email.
 */
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  /** Hide the nav (used by the login page). */
  bare?: boolean;
}
const { title, bare = false } = Astro.props;
const admin = Astro.locals.admin;

const path = Astro.url.pathname;
const onEvents = path === '/admin' || path.startsWith('/admin/events');
const onTestimonials = path.startsWith('/admin/testimonials');
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#15181a" />
    <title>{title} · Admin · Männerkreis</title>
    <Font cssVariable="--font-bricolage" preload />
    <Font cssVariable="--font-dm-sans" />
    <Font cssVariable="--font-plex-mono" />
    <ClientRouter />
  </head>
  <body>
    {
      !bare && (
        <header class="topbar">
          <nav class="nav">
            <a href="/admin" class="brand">
              <span class="brand-ring" aria-hidden="true" />
              männerkreis
            </a>
            <div class="nav-links">
              <a href="/admin" class:list={['nav-link', { active: onEvents }]}>
                Veranstaltungen
              </a>
              <a href="/admin/testimonials" class:list={['nav-link', { active: onTestimonials }]}>
                Stimmen
              </a>
            </div>
          </nav>
          <div class="user">
            {admin && <span class="user-name">{admin}</span>}
            <button type="button" id="admin-logout" class="btn btn--ghost btn--sm">
              Abmelden
            </button>
          </div>
        </header>
      )
    }
    <main class="main" class:list={{ 'main--bare': bare }}>
      <slot />
    </main>

    <div id="toasts" class="toasts" aria-live="polite" aria-atomic="false" transition:persist></div>

    <script>
      import { actions } from 'astro:actions';

      type ToastKind = 'ok' | 'err';
      declare global {
        interface Window {
          adminToast?: (kind: ToastKind, text: string) => void;
        }
      }

      // Shared toast — defined once, persists on `window` across view-transition
      // swaps. Components call `window.adminToast('ok' | 'err', text)`.
      if (!window.adminToast) {
        window.adminToast = (kind: ToastKind, text: string) => {
          const host = document.getElementById('toasts');
          if (!host) return;
          const el = document.createElement('div');
          el.className = `toast toast--${kind}`;
          el.setAttribute('role', kind === 'err' ? 'alert' : 'status');
          el.textContent = text;
          host.appendChild(el);
          requestAnimationFrame(() => el.classList.add('in'));
          setTimeout(() => {
            el.classList.remove('in');
            el.addEventListener('transitionend', () => el.remove(), { once: true });
          }, 3600);
        };
      }

      // Re-bind logout after every navigation (`astro:page-load` fires on first
      // load and after each swap; the button is a fresh node each time).
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('admin-logout');
        btn?.addEventListener('click', async () => {
          await actions.logout();
          window.location.href = '/admin/login';
        });
      });
    </script>

    <style is:global>
      :root {
        /* Dusk Circle palette */
        --bg: #15181a;
        --surface: #1e2325;
        --surface-2: #252b2d;
        --line: rgba(236, 228, 214, 0.1);
        --line-strong: rgba(236, 228, 214, 0.2);
        --text: #ece4d6;
        --muted: #a39a8d;
        --faint: #756e64;
        --ember: #e08a4a;
        --ember-bright: #f2a062;
        --ember-soft: rgba(224, 138, 74, 0.14);
        --ember-line: rgba(224, 138, 74, 0.38);
        --sage: #8fb08c;
        --sage-soft: rgba(143, 176, 140, 0.16);
        --danger: #e0715f;
        --danger-soft: rgba(224, 113, 95, 0.15);
        --focus: rgba(224, 138, 74, 0.5);

        --r: 14px;
        --r-sm: 9px;
        --shadow: 0 16px 40px -20px rgba(0, 0, 0, 0.7);
        --ease: 0.2s cubic-bezier(0.4, 0, 0.2, 1);

        --font-display: var(--font-bricolage), system-ui, sans-serif;
        --font-body: var(--font-dm-sans), system-ui, sans-serif;
        --font-mono: var(--font-plex-mono), ui-monospace, monospace;
      }

      * {
        box-sizing: border-box;
      }
      /* `hidden` must win over component `display` rules (e.g. flex/grid). */
      [hidden] {
        display: none !important;
      }
      html {
        -webkit-text-size-adjust: 100%;
      }
      body {
        margin: 0;
        min-height: 100dvh;
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.55;
        color: var(--text);
        background: radial-gradient(120% 80% at 100% 0%, rgba(224, 138, 74, 0.06), transparent 60%), var(--bg);
        -webkit-font-smoothing: antialiased;
      }
      ::selection {
        background: var(--ember-soft);
      }

      /* ── Topbar ── */
      .topbar {
        position: sticky;
        top: 0;
        z-index: 30;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem 1.25rem;
        flex-wrap: wrap;
        padding: 0.75rem clamp(1rem, 4vw, 2rem);
        background: color-mix(in srgb, var(--bg) 78%, transparent);
        backdrop-filter: saturate(1.3) blur(14px);
        border-bottom: 1px solid var(--line);
      }
      .nav {
        display: flex;
        align-items: center;
        gap: clamp(0.75rem, 3vw, 1.75rem);
        flex-wrap: wrap;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.15rem;
        letter-spacing: -0.02em;
        color: var(--text);
        text-decoration: none;
      }
      .brand-ring {
        width: 0.85rem;
        height: 0.85rem;
        border-radius: 50%;
        border: 2.5px solid var(--ember);
        box-shadow: 0 0 0 3px var(--ember-soft);
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.3rem;
      }
      .nav-link {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        transition:
          color var(--ease),
          background var(--ease);
      }
      .nav-link:hover {
        color: var(--text);
        background: var(--surface);
      }
      .nav-link.active {
        color: var(--ember-bright);
        background: var(--ember-soft);
      }
      .user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      .user-name {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--faint);
        max-width: 13rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* ── Layout ── */
      .main {
        max-width: 940px;
        margin: 0 auto;
        padding: clamp(1.5rem, 4vw, 2.75rem) clamp(1rem, 4vw, 2rem) 5rem;
      }
      .main--bare {
        display: grid;
        place-items: center;
        min-height: calc(100dvh - 0px);
      }

      /* ── Type ── */
      h1 {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0;
      }
      h2 {
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 0;
      }
      a {
        color: var(--ember);
      }
      .mono {
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
      }
      .muted {
        color: var(--muted);
      }
      .faint {
        color: var(--faint);
      }
      /* Section eyebrow — small mono label above a heading. */
      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--faint);
      }

      /* ── Page header row ── */
      .pagehead {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
      }
      .pagehead__titles {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }

      /* ── Card ── */
      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--r);
        padding: clamp(1rem, 3vw, 1.5rem);
      }

      /* ── Buttons ── */
      .btn {
        --_bg: var(--ember);
        --_fg: #1a130c;
        --_bd: var(--ember);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        font: inherit;
        font-weight: 600;
        font-size: 0.92rem;
        line-height: 1;
        padding: 0.62rem 1.05rem;
        border: 1px solid var(--_bd);
        border-radius: var(--r-sm);
        background: var(--_bg);
        color: var(--_fg);
        text-decoration: none;
        white-space: nowrap;
        cursor: pointer;
        transition:
          filter var(--ease),
          background var(--ease),
          border-color var(--ease),
          color var(--ease),
          transform var(--ease);
      }
      .btn:hover {
        filter: brightness(1.08);
      }
      .btn:active {
        transform: translateY(1px);
      }
      .btn:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px var(--focus);
      }
      .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        filter: none;
        transform: none;
      }
      .btn--ghost {
        --_bg: transparent;
        --_fg: var(--muted);
        --_bd: var(--line-strong);
      }
      .btn--ghost:hover {
        --_fg: var(--text);
        --_bg: var(--surface-2);
        filter: none;
      }
      .btn--danger {
        --_bg: transparent;
        --_fg: var(--danger);
        --_bd: var(--danger-soft);
      }
      .btn--danger:hover {
        --_bg: var(--danger);
        --_fg: #1a130c;
        --_bd: var(--danger);
        filter: none;
      }
      .btn--sm {
        font-size: 0.8rem;
        padding: 0.42rem 0.75rem;
      }
      .btn--block {
        width: 100%;
      }

      /* ── Forms ── */
      .field {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-bottom: 1.1rem;
      }
      label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--muted);
      }
      input[type='text'],
      input[type='email'],
      input[type='password'],
      input[type='number'],
      input[type='date'],
      input[type='time'],
      input[type='url'],
      textarea,
      select {
        width: 100%;
        font: inherit;
        font-size: 0.95rem;
        padding: 0.6rem 0.75rem;
        color: var(--text);
        background: var(--bg);
        border: 1px solid var(--line-strong);
        border-radius: var(--r-sm);
        transition:
          border-color var(--ease),
          box-shadow var(--ease);
      }
      input[type='date'],
      input[type='time'],
      input[type='number'] {
        font-family: var(--font-mono);
      }
      input:focus,
      textarea:focus,
      select:focus {
        outline: none;
        border-color: var(--ember);
        box-shadow: 0 0 0 3px var(--focus);
      }
      input::placeholder,
      textarea::placeholder {
        color: var(--faint);
      }
      textarea {
        min-height: 6.5rem;
        resize: vertical;
        line-height: 1.5;
      }
      /* dark-friendly native pickers */
      input[type='date']::-webkit-calendar-picker-indicator,
      input[type='time']::-webkit-calendar-picker-indicator {
        filter: invert(0.8) sepia(0.3) saturate(2) hue-rotate(-10deg);
        cursor: pointer;
      }
      .field-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 0 1rem;
      }
      .check {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 500;
        color: var(--text);
        cursor: pointer;
      }
      .check input {
        width: 1.15rem;
        height: 1.15rem;
        accent-color: var(--ember);
        cursor: pointer;
      }

      /* ── Badges ── */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        padding: 0.22rem 0.6rem;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        color: var(--muted);
        white-space: nowrap;
      }
      .badge::before {
        content: '';
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 50%;
        background: currentColor;
      }
      .badge--live {
        color: var(--sage);
        border-color: var(--sage-soft);
        background: var(--sage-soft);
      }
      .badge--draft {
        color: var(--faint);
      }
      .badge--wait {
        color: var(--ember);
        border-color: var(--ember-line);
        background: var(--ember-soft);
      }
      .badge--off {
        color: var(--faint);
        opacity: 0.8;
      }

      /* ── Capacity ring ── */
      .ring {
        display: inline-grid;
        place-items: center;
        position: relative;
      }
      .ring svg {
        display: block;
        transform: rotate(-90deg);
      }
      .ring__track {
        stroke: var(--line-strong);
      }
      .ring__fill {
        stroke: var(--ember);
        stroke-linecap: round;
        transition: stroke-dashoffset var(--ease);
      }
      .ring.is-full .ring__fill {
        stroke: var(--sage);
      }
      .ring__label {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
        font-weight: 500;
        color: var(--text);
        line-height: 1;
      }

      /* ── Empty state ── */
      .empty {
        text-align: center;
        padding: 3rem 1rem;
        border: 1px dashed var(--line-strong);
        border-radius: var(--r);
        color: var(--muted);
      }

      /* ── Toasts ── */
      .toasts {
        position: fixed;
        left: 50%;
        bottom: 1.25rem;
        transform: translateX(-50%);
        z-index: 60;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        width: min(92vw, 26rem);
        pointer-events: none;
      }
      .toast {
        padding: 0.7rem 1rem;
        border-radius: var(--r-sm);
        font-size: 0.88rem;
        font-weight: 500;
        background: var(--surface-2);
        border: 1px solid var(--line-strong);
        color: var(--text);
        box-shadow: var(--shadow);
        opacity: 0;
        transform: translateY(0.5rem);
        transition:
          opacity var(--ease),
          transform var(--ease);
      }
      .toast.in {
        opacity: 1;
        transform: translateY(0);
      }
      .toast--ok {
        border-color: var(--sage-soft);
        color: var(--sage);
      }
      .toast--err {
        border-color: var(--danger-soft);
        color: var(--danger);
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>
