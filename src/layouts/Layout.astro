---
import '../styles/app.css';
import { Font } from 'astro:assets';
import SeoHead from '../components/SeoHead.astro';
import SpriteDefs from '../components/SpriteDefs.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  robots?: string;
  schemas?: Record<string, unknown>[];
}

const props = Astro.props;

// The "next event" CTAs ([data-event-cta]) are HIDDEN by default (CSS) and
// revealed at runtime by the client only when an upcoming event is actually
// scheduled (see lib/event-cta.ts). They can't be gated at build time because
// these pages are prerendered and PocketBase isn't reachable during the build.
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    {
      /* Flag JS synchronously so reveals only hide their elements when JS is
        available — without JS, all [data-reveal] content stays visible. */
    }
    <script is:inline>
      document.documentElement.classList.add('motion-ready');
    </script>
    {
      /* Native Astro fonts (config in astro.config.mjs). Preload Playfair —
        the hero heading is the LCP; DM Sans loads without a preload race. */
    }
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-dm-sans" />
    <SeoHead {...props} />
  </head>
  <body>
    {
      /* Top sentinel: a static, in-flow target at position 0 for scroll-to-top. */
    }
    <span id="top" aria-hidden="true"></span>

    <SpriteDefs />

    {
      /* Editorial side rails — decorative magazine framing, hidden on small screens */
    }
    <aside class="side-rail side-rail--left" aria-hidden="true">
      <span class="side-rail__text">Männerkreis · Niederbayern</span>
    </aside>
    <aside class="side-rail side-rail--right" aria-hidden="true">
      <span class="side-rail__text">Straubing · Bayern</span>
    </aside>

    <a href="#main" class="skip-link">Zum Inhalt springen</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <ScrollToTop />

    <script>
      import '../lib/client';
    </script>
  </body>
</html>

<style is:global>
  @layer components {
    .skip-link {
      position: absolute;
      inset-block-start: -100%;
      inset-inline-start: 50%;
      z-index: var(--z-toast);
      padding: 1rem 2rem;
      font-size: 0.875rem;
      color: var(--text-on-dark);
      background: var(--bg-section-alt);
      border-radius: var(--radius-full);
      transform: translateX(-50%);
      transition: inset-block-start var(--motion-quick);
    }

    .skip-link:focus {
      inset-block-start: var(--space-sm);
    }
  }
</style>
