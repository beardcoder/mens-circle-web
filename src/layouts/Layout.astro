---
import '../styles/app.css';
import SeoHead from '../components/SeoHead.astro';
import SpriteDefs from '../components/SpriteDefs.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { hasUpcomingEvent } from '../lib/pocketbase-build';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  robots?: string;
  schemas?: Record<string, unknown>[];
}

const props = Astro.props;

// Resolve once at build time whether a "next event" is scheduled, so the
// event CTAs can be shown/hidden statically. This removes the per-visitor
// runtime `/api/public/events/next` request that previously sat on the
// critical path (~400ms) and made the header CTA flicker (it rendered, then
// JS removed it). The CTAs default to HIDDEN; the class below opts them in
// only when an upcoming event is confirmed, so an empty/unknown state never
// flashes a dead button.
const showEventCtas = (await hasUpcomingEvent()) === true;
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    {
      /* Flag JS synchronously so reveals only hide their elements when JS is
        available — without JS, all [data-reveal] content stays visible. */
    }
    <script is:inline>
      document.documentElement.classList.add('motion-ready');
    </script>
    <SeoHead {...props} />
  </head>
  <body class:list={{ 'has-upcoming-event': showEventCtas }}>
    {
      /* Top sentinel: a static, in-flow target at position 0 for scroll-to-top. */
    }
    <span id="top" aria-hidden="true"></span>

    <SpriteDefs />

    {
      /* Editorial side rails — decorative magazine framing, hidden on small screens */
    }
    <aside class="side-rail side-rail--left" aria-hidden="true">
      <span class="side-rail__text">Männerkreis · Niederbayern</span>
    </aside>
    <aside class="side-rail side-rail--right" aria-hidden="true">
      <span class="side-rail__text">Straubing · Bayern</span>
    </aside>

    <a href="#main" class="skip-link">Zum Inhalt springen</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <ScrollToTop />

    <script>
      import '../lib/client';
    </script>
  </body>
</html>
