---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import TextSection from '../components/blocks/TextSection.astro';
import datenschutz from '../content/legal/datenschutz.json';
import impressum from '../content/legal/impressum.json';

// Static legal pages — no live data, prerendered to plain HTML at build time.
export const prerender = true;

export function getStaticPaths() {
  const pages = { impressum, datenschutz };
  return Object.entries(pages).map(([slug, page]) => ({
    params: { slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<Layout
  title={page.meta?.title ?? page.title}
  description={page.meta?.description}
  robots={page.robots ?? 'noindex, nofollow'}
>
  <PageHero data={{ title: page.title, align: 'center' }} />
  <TextSection data={{ content: page.content, anchor: '' }} />
</Layout>

<style is:global>
  @layer sections {
    .legal-page {
      background: var(--bg-primary);
      padding-block-start: var(--header-clearance);
      min-block-size: 100vh;
    }

    .legal-content {
      margin-inline: auto;
      padding-inline: var(--space-md);
      padding-block-end: var(--space-xl);
      max-inline-size: var(--container-prose);
    }

    .legal-content h1 {
      margin-block-end: var(--space-xl);
      border-block-end: 1px solid var(--border-light);
      padding-block-end: var(--space-md);
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      letter-spacing: -0.03em;
    }

    .legal-content h2 {
      margin-block: var(--space-xl) var(--space-sm);
      font-size: 1.5rem;
      letter-spacing: -0.02em;
    }

    .legal-content h3 {
      margin-block: var(--space-lg) var(--space-xs);
      font-size: 1.125rem;
    }

    .legal-content p,
    .legal-content ul,
    .legal-content ol {
      margin-block-end: var(--space-sm);
      color: var(--text-secondary);
      font-size: 1rem;
      line-height: var(--leading-relaxed);
    }

    .legal-content ul,
    .legal-content ol {
      padding-inline-start: 1.25rem;
    }

    .legal-content li {
      margin-block-end: 0.5rem;
    }

    .legal-content a {
      color: var(--accent-primary);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .legal-content a:hover {
      color: var(--color-earth-warm);
    }

    .legal-content strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    .legal-content table {
      margin-block: var(--space-md);
      border-collapse: collapse;
      inline-size: 100%;
    }

    .legal-content th,
    .legal-content td {
      border-block-end: 1px solid var(--border-light);
      padding: var(--space-sm);
      text-align: start;
    }

    .legal-content th {
      color: var(--text-primary);
      font-weight: 600;
    }
  }
</style>
