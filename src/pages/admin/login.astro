---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { adminConfigured } from '../../server/auth';

const hasError = Astro.url.searchParams.has('error');
const configured = adminConfigured();
---

<AdminLayout title="Anmelden">
  <h1>Admin-Anmeldung</h1>
  {!configured && (
    <div class="panel">
      <p class="muted">
        Es ist noch kein Admin konfiguriert. Setze die Umgebungsvariablen
        <code>ADMIN_EMAIL</code> und <code>ADMIN_PASSWORD</code> und starte neu.
      </p>
    </div>
  )}
  <div class="panel" style="max-width:380px;">
    {hasError && <p style="color:var(--danger);margin-top:0;">E-Mail oder Passwort ist falsch.</p>}
    <form method="post" action="/api/admin/login">
      <label for="email">E-Mail</label>
      <input id="email" name="email" type="email" required autocomplete="username" />
      <label for="password">Passwort</label>
      <input id="password" name="password" type="password" required autocomplete="current-password" />
      <div style="margin-top:1.25rem;">
        <button class="btn" type="submit" disabled={!configured}>Anmelden</button>
      </div>
    </form>
  </div>
</AdminLayout>
