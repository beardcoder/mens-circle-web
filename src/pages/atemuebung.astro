---
import Layout from '../layouts/Layout.astro';
import BreathingExperience from '../components/BreathingExperience.astro';

// Embedded breathing tool — the public-site page. Opened from the nav/footer it
// presents inside the normal site chrome (header/footer), with the instructions
// shown inline. The chrome-less, installable full-screen variant lives at
// /atemuebung/app and is reached via the CTA below.
export const prerender = true;

const siteUrl = Astro.site ?? new URL('https://mens-circle.de');
const canonical = new URL(Astro.url.pathname, siteUrl).href;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: siteUrl.origin },
      { '@type': 'ListItem', position: 2, name: 'Atemübung', item: canonical },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': canonical,
    url: canonical,
    name: 'Atemübung',
    description: 'Eine geführte, interaktive Atemübung im Stil der Wim-Hof-Methode.',
    inLanguage: 'de-DE',
    isPartOf: { '@id': `${siteUrl.origin}/#website` },
  },
];
---

<Layout
  title="Atemübung – Männerkreis Niederbayern/ Straubing"
  description="Eine geführte, interaktive Atemübung im Stil der Wim-Hof-Methode. Drei Runden bewusster Atem für Klarheit, Energie und innere Ruhe."
  schemas={schemas}
>
  <section class="atem-intro">
    <p class="atem-intro__eyebrow">Atemübung</p>
    <h1 class="atem-intro__title">Komm bei dir an.</h1>
    <p class="atem-intro__lede">
      Eine geführte, interaktive Atemübung im Stil der Wim-Hof-Methode — drei Runden bewusster Atem für Klarheit,
      Energie und innere Ruhe. Setze oder lege dich entspannt hin und folge dem Kreis.
    </p>

    <ol class="breathing__steps atem-intro__steps">
      <li><strong>Tief atmen:</strong> 35 kräftige Atemzüge — vollständig einatmen, locker ausatmen.</li>
      <li><strong>Halten:</strong> Nach der letzten Ausatmung den Atem so lange wie möglich anhalten.</li>
      <li><strong>Erholung:</strong> Tief einatmen und 15 Sekunden halten. Dann normal weiteratmen.</li>
    </ol>
    <p class="breathing__warning atem-intro__warning">
      <strong>Wichtig:</strong> Übe niemals im Wasser oder beim Autofahren. Setze oder lege dich entspannt hin.
    </p>
  </section>

  <BreathingExperience />

  <section class="atem-cta">
    <p class="atem-cta__text">Lieber ablenkungsfrei? Öffne die Übung im Vollbild oder installiere sie als App.</p>
    <a class="btn btn--primary btn--large" href="/atemuebung/app">Im Vollbild öffnen</a>
  </section>
</Layout>

<style>
  .atem-intro {
    display: grid;
    justify-items: start;
    gap: var(--space-sm);
    margin-inline: auto;
    padding-block-start: var(--space-3xl);
    padding-inline: var(--space-md);
    inline-size: 100%;
    max-inline-size: 48rem;
  }

  .atem-intro__eyebrow {
    color: var(--color-terracotta);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .atem-intro__title {
    margin: 0;
    font-weight: 500;
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
  }

  .atem-intro__lede {
    margin-block: var(--space-2xs) var(--space-sm);
    color: var(--text-secondary);
    font-size: var(--text-section-body);
    line-height: var(--leading-relaxed);
  }

  /* The shared step/warning styling targets `--text-on-dark`; on the light page
     re-point those tones to the page's own ink colours. */
  .atem-intro__steps {
    margin-block-end: var(--space-md);
    color: var(--text-secondary);
  }

  .atem-intro__steps strong,
  .atem-intro__warning strong {
    color: var(--text-primary);
  }

  .atem-intro__warning {
    justify-self: stretch;
    color: var(--text-primary);
  }

  .atem-cta {
    display: grid;
    justify-items: center;
    gap: var(--space-md);
    margin-inline: auto;
    padding-block: var(--space-2xl) var(--space-3xl);
    padding-inline: var(--space-md);
    max-inline-size: 48rem;
    text-align: center;
  }

  .atem-cta__text {
    margin: 0;
    color: var(--text-secondary);
    font-size: var(--text-section-body);
  }
</style>
