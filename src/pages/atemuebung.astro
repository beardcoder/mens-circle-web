---
import Layout from '../layouts/Layout.astro';
import BreathingApp from '../components/islands/BreathingApp.svelte';

// Self-contained breathing tool — no live data, prerendered at build time.
export const prerender = true;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: '/' },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Atemübung',
        item: '/atemuebung',
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Atemübung',
    description:
      'Eine geführte, interaktive Atemübung im Stil der Wim-Hof-Methode.',
  },
];
---

<Layout
  title="Atemübung – Männerkreis Niederbayern/ Straubing"
  description="Eine geführte, interaktive Atemübung im Stil der Wim-Hof-Methode. Drei Runden bewusster Atem für Klarheit, Energie und innere Ruhe."
  schemas={schemas}
  manifest="/atemuebung.webmanifest"
  webAppTitle="Atemübung"
  viewport="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no"
  bare
>
  <section class="breathing-section breathing-screen">
    <h1 class="sr-only">Atemübung</h1>

    <button
      type="button"
      class="breathing-info-btn"
      id="info-open"
      aria-haspopup="dialog"
      aria-label="So funktioniert es"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <circle
          cx="12"
          cy="12"
          r="9"
          fill="none"
          stroke="currentColor"
          stroke-width="2"></circle>
        <path
          d="M12 11v5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
        <circle cx="12" cy="7.5" r="1.25" fill="currentColor"></circle>
      </svg>
    </button>

    <BreathingApp client:visible />

    <dialog class="info-modal" id="info-modal" aria-labelledby="info-title">
      <div class="info-modal__content">
        <button
          type="button"
          class="info-modal__close"
          id="info-close"
          aria-label="Schließen"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M6 6l12 12M18 6L6 18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
        </button>

        <h2 id="info-title">So funktioniert es</h2>
        <ol class="breathing__steps">
          <li>
            <strong>Tief atmen:</strong> 35 kräftige Atemzüge — vollständig einatmen,
            locker ausatmen.
          </li>
          <li>
            <strong>Halten:</strong> Nach der letzten Ausatmung den Atem so lange
            wie möglich anhalten.
          </li>
          <li>
            <strong>Erholung:</strong> Tief einatmen und 15 Sekunden halten. Dann
            normal weiteratmen.
          </li>
        </ol>
        <p class="breathing__warning">
          <strong>Wichtig:</strong> Übe niemals im Wasser oder beim Autofahren. Setze
          oder lege dich entspannt hin.
        </p>

        <button
          type="button"
          id="pwa-install"
          class="breathing__install"
          hidden
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          Als App installieren
        </button>
      </div>
    </dialog>
  </section>
</Layout>

<script>
  // Progressive web app wiring for the breathing exercise: register the service
  // worker (offline + installability) and surface a native install prompt
  // through an in-page button when the browser offers one.
  type InstallPromptEvent = Event & {
    prompt: () => void;
    userChoice: Promise<{ outcome: string }>;
  };

  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js').catch(() => {
        /* registration is best-effort; the app works fine without it */
      });
    });
  }

  const installButton =
    document.querySelector<HTMLButtonElement>('#pwa-install');

  const isStandalone =
    window.matchMedia('(display-mode: standalone)').matches ||
    (navigator as Navigator & { standalone?: boolean }).standalone === true;

  let deferredPrompt: InstallPromptEvent | null = null;

  window.addEventListener('beforeinstallprompt', (event) => {
    event.preventDefault();
    deferredPrompt = event as InstallPromptEvent;

    if (installButton && !isStandalone) installButton.hidden = false;
  });

  installButton?.addEventListener('click', async () => {
    if (!deferredPrompt) return;

    installButton.hidden = true;
    deferredPrompt.prompt();
    await deferredPrompt.userChoice;
    deferredPrompt = null;
  });

  window.addEventListener('appinstalled', () => {
    if (installButton) installButton.hidden = true;
  });

  // Instructions live in a native <dialog> opened from the floating info
  // button, so the main screen stays just the app. showModal() gives the
  // focus trap, Escape-to-close and backdrop for free; a click outside the
  // card (on the dialog/backdrop) also closes it.
  const infoModal = document.querySelector<HTMLDialogElement>('#info-modal');
  const infoOpen = document.querySelector<HTMLButtonElement>('#info-open');
  const infoClose = document.querySelector<HTMLButtonElement>('#info-close');

  infoOpen?.addEventListener('click', () => {
    if (infoModal && !infoModal.open) infoModal.showModal();
  });

  infoClose?.addEventListener('click', () => infoModal?.close());

  infoModal?.addEventListener('click', (event) => {
    if (event.target !== infoModal) return;

    const r = infoModal.getBoundingClientRect();
    const inside =
      event.clientX >= r.left &&
      event.clientX <= r.right &&
      event.clientY >= r.top &&
      event.clientY <= r.bottom;

    if (!inside) infoModal.close();
  });
</script>

<style is:global>
  /* @property kept unlayered — must be at top level for interpolation to work */
  @property --ring-scale {
    syntax: '<number>';
    initial-value: 1;
    inherits: true;
  }

  @layer sections {
    .breathing-section {
      --breathing-bg: var(--color-earth-deep);
      --breathing-bg-deep: var(--color-ink);
      --breathing-accent: var(--color-terracotta-light);
      --breathing-accent-dim: var(--color-terracotta);
      --breathing-warm: var(--color-sand);
      --_surface-noise-opacity: 0.03;

      position: relative;
      overflow: hidden;
      color: var(--text-on-dark);
      background:
        radial-gradient(
          ellipse at 50% 0%,
          color-mix(in oklch, var(--breathing-accent-dim) 14%, transparent),
          transparent 60%
        ),
        radial-gradient(
          ellipse at 85% 92%,
          color-mix(in oklch, var(--breathing-warm) 10%, transparent),
          transparent 55%
        ),
        linear-gradient(
          160deg,
          var(--breathing-bg) 0%,
          var(--breathing-bg-deep) 100%
        );
    }

    .breathing-section::before {
      z-index: 0;
    }

    /* One screen: the app fills the viewport but with real breathing room top
       and bottom, so the circle (and its rings) never touch the edges. */
    .breathing-screen {
      display: grid;
      grid-template-rows: 1fr;
      justify-items: center;
      min-block-size: 100svh;
      min-block-size: 100dvh;
      padding-block: max(var(--space-md), var(--safe-area-inset-top))
        max(var(--space-md), var(--safe-area-inset-bottom));
      padding-inline: max(var(--space-md), var(--safe-area-inset-left))
        max(var(--space-md), var(--safe-area-inset-right));
    }

    .breathing-screen > * {
      position: relative;
      z-index: 1;
    }

    /* Floating info button — opens the instructions dialog. */
    .breathing-info-btn {
      position: absolute;
      inset-block-start: max(var(--space-sm), var(--safe-area-inset-top));
      inset-inline-end: max(var(--space-sm), var(--safe-area-inset-right));
      z-index: 2;
      display: grid;
      place-items: center;
      inline-size: 2.75rem;
      block-size: 2.75rem;
      color: color-mix(in oklch, var(--text-on-dark) 70%, transparent);
      cursor: pointer;
      background: color-mix(in oklch, var(--color-sand) 8%, transparent);
      border: 1px solid color-mix(in oklch, var(--color-sand) 16%, transparent);
      border-radius: var(--radius-full);
      backdrop-filter: blur(8px);
      transition:
        color var(--motion-quick),
        background-color var(--motion-quick);
    }

    @media (hover: hover) and (pointer: fine) {
      .breathing-info-btn:hover {
        color: var(--text-on-dark);
        background: color-mix(in oklch, var(--color-sand) 16%, transparent);
      }
    }

    .breathing-info-btn:focus-visible {
      outline: 2px solid var(--breathing-accent);
      outline-offset: 3px;
    }

    .breathing-info-btn svg {
      inline-size: 1.4rem;
      block-size: 1.4rem;
    }

    /* Instructions dialog (native <dialog> + showModal): focus trap, Escape
       and backdrop for free, with a smooth open/close via @starting-style. */
    .info-modal {
      inline-size: min(420px, calc(100vw - 2 * var(--space-md)));
      max-block-size: calc(100dvh - 2 * var(--space-md));
      padding: 0;
      margin: auto;
      color: var(--text-on-dark);
      background: color-mix(in oklch, var(--breathing-bg) 86%, black);
      border: 1px solid color-mix(in oklch, var(--color-sand) 16%, transparent);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-2xl);
      opacity: 0;
      scale: 0.96;
      translate: 0 12px;
      transition:
        opacity var(--motion-standard),
        scale var(--motion-standard),
        translate var(--motion-standard),
        overlay var(--motion-standard) allow-discrete,
        display var(--motion-standard) allow-discrete;
    }

    .info-modal[open] {
      opacity: 1;
      scale: 1;
      translate: 0 0;
    }

    @starting-style {
      .info-modal[open] {
        opacity: 0;
        scale: 0.96;
        translate: 0 12px;
      }
    }

    .info-modal::backdrop {
      background-color: color-mix(in oklch, black 0%, transparent);
      backdrop-filter: blur(0);
      transition:
        background-color var(--motion-standard),
        backdrop-filter var(--motion-standard),
        overlay var(--motion-standard) allow-discrete,
        display var(--motion-standard) allow-discrete;
    }

    .info-modal[open]::backdrop {
      background-color: color-mix(in oklch, black 55%, transparent);
      backdrop-filter: blur(4px);
    }

    @starting-style {
      .info-modal[open]::backdrop {
        background-color: color-mix(in oklch, black 0%, transparent);
        backdrop-filter: blur(0);
      }
    }

    .info-modal__content {
      position: relative;
      max-block-size: calc(100dvh - 2 * var(--space-md));
      padding: var(--space-lg);
      overflow-y: auto;
    }

    .info-modal__close {
      position: absolute;
      inset-block-start: var(--space-xs);
      inset-inline-end: var(--space-xs);
      display: grid;
      place-items: center;
      inline-size: 2.25rem;
      block-size: 2.25rem;
      color: color-mix(in oklch, var(--text-on-dark) 65%, transparent);
      cursor: pointer;
      background: none;
      border: none;
      border-radius: var(--radius-full);
      transition:
        color var(--motion-quick),
        background-color var(--motion-quick);
    }

    @media (hover: hover) and (pointer: fine) {
      .info-modal__close:hover {
        color: var(--text-on-dark);
        background: color-mix(in oklch, var(--color-sand) 12%, transparent);
      }
    }

    .info-modal__close:focus-visible {
      outline: 2px solid var(--breathing-accent);
      outline-offset: 2px;
    }

    .info-modal__close svg {
      inline-size: 1.25rem;
      block-size: 1.25rem;
    }

    .info-modal__content h2 {
      margin-block-end: var(--space-md);
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 500;
      color: var(--text-on-dark);
      letter-spacing: -0.01em;
    }

    @media (prefers-reduced-motion: reduce) {
      .info-modal {
        scale: 1;
        translate: 0;
        transition:
          opacity var(--motion-quick),
          overlay var(--motion-quick) allow-discrete,
          display var(--motion-quick) allow-discrete;
      }

      @starting-style {
        .info-modal[open] {
          scale: 1;
          translate: 0;
        }
      }

      .info-modal::backdrop,
      .info-modal[open]::backdrop {
        backdrop-filter: none;
      }
    }

    .breathing__steps {
      padding-inline-start: 1.25rem;
      margin-block-end: var(--space-md);
      font-size: var(--text-section-body);
      line-height: var(--leading-relaxed);
      color: color-mix(in oklch, var(--text-on-dark) 72%, transparent);
    }

    .breathing__steps li {
      margin-block-end: var(--space-xs);
    }

    .breathing__steps strong {
      color: var(--text-on-dark);
    }

    .breathing__warning {
      padding: var(--space-sm) var(--space-md);
      font-size: 0.9375rem;
      color: var(--text-on-dark);
      background: color-mix(in oklch, var(--color-warning) 12%, transparent);
      border-inline-start: 3px solid var(--color-warning);
      border-radius: var(--radius-md);
    }

    /* Shown only when the browser offers a native install (beforeinstallprompt). */
    .breathing__install {
      display: inline-flex;
      gap: var(--space-xs);
      align-items: center;
      align-self: start;
      margin-block-start: var(--space-md);
      padding: var(--space-xs) var(--space-md);
      font-family: var(--font-body);
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--text-on-dark);
      cursor: pointer;
      background: color-mix(in oklch, var(--breathing-accent) 14%, transparent);
      border: 1px solid
        color-mix(in oklch, var(--breathing-accent) 45%, transparent);
      border-radius: var(--radius-full);
      transition:
        background-color var(--motion-quick),
        border-color var(--motion-quick),
        translate var(--motion-quick);
    }

    @media (hover: hover) and (pointer: fine) {
      .breathing__install:hover {
        background: color-mix(
          in oklch,
          var(--breathing-accent) 22%,
          transparent
        );
        border-color: color-mix(
          in oklch,
          var(--breathing-accent) 60%,
          transparent
        );
        translate: 0 -2px;
      }
    }

    .breathing__install:focus-visible {
      outline: 2px solid var(--breathing-accent);
      outline-offset: 3px;
    }

    .breathing__install svg {
      inline-size: 1.1rem;
      block-size: 1.1rem;
    }

    .breathing-app {
      --breathing-cycle-ms: 3600ms;

      position: relative;
      display: grid;
      grid-template-rows: 1fr auto auto auto;
      gap: clamp(var(--space-sm), 3vw, var(--space-md));
      inline-size: 100%;
      max-inline-size: 640px;
      /* Fill the full screen height it now owns, top to bottom. */
      min-block-size: 100%;
      color: var(--text-on-dark);
    }

    .breathing-app__stage {
      display: grid;
      place-items: center;
      min-block-size: 0;
    }

    .breathing-app__circle {
      --size: min(74vw, 46svh, 400px);

      position: relative;
      display: grid;
      place-items: center;
      inline-size: var(--size);
      block-size: var(--size);
      text-align: center;
      cursor: pointer;
      isolation: isolate;
      transition: filter var(--duration-slower) var(--ease-settle);
    }

    .breathing-app[data-phase='breathing'] .breathing-app__circle,
    .breathing-app[data-phase='retention'] .breathing-app__circle,
    .breathing-app[data-phase='recovery'] .breathing-app__circle {
      cursor: default;
    }

    .breathing-app__ring {
      position: absolute;
      background: radial-gradient(
        circle at 32% 28%,
        color-mix(in oklch, var(--breathing-accent) 38%, transparent) 0%,
        color-mix(in oklch, var(--breathing-accent-dim) 22%, transparent) 45%,
        color-mix(in oklch, var(--breathing-accent-dim) 8%, transparent) 75%,
        transparent 100%
      );
      border-radius: var(--radius-full);
      box-shadow:
        inset 0 0 50px
          color-mix(in oklch, var(--breathing-accent) 22%, transparent),
        inset 0 0 2px
          color-mix(in oklch, var(--breathing-accent) 38%, transparent);
      mix-blend-mode: screen;
      transform: scale(var(--ring-scale));
      transition:
        --ring-scale var(--duration-slower) var(--ease-settle),
        background var(--duration-slower) var(--ease-settle),
        box-shadow var(--duration-slower) var(--ease-settle);
      will-change: transform;
    }

    .breathing-app__ring--1 {
      inset: 0;
      opacity: 0.42;
    }

    .breathing-app__ring--2 {
      inset: 22%;
      opacity: 0.6;
    }

    .breathing-app__ring--3 {
      inset: 42%;
      opacity: 0.85;
    }

    .breathing-app[data-phase='idle'] .breathing-app__ring--1,
    .breathing-app[data-phase='complete'] .breathing-app__ring--1 {
      animation: breathing-idle 7s var(--ease-precise) infinite;
    }

    .breathing-app[data-phase='idle'] .breathing-app__ring--2,
    .breathing-app[data-phase='complete'] .breathing-app__ring--2 {
      animation: breathing-idle 7s var(--ease-precise) infinite -0.6s;
    }

    .breathing-app[data-phase='idle'] .breathing-app__ring--3,
    .breathing-app[data-phase='complete'] .breathing-app__ring--3 {
      animation: breathing-idle-inner 7s var(--ease-precise) infinite -1.2s;
    }

    .breathing-app__circle[data-motion='wave'] .breathing-app__ring--1 {
      transition: none;
      animation: breathing-wave-outer var(--breathing-cycle-ms)
        var(--ease-precise) infinite;
    }

    .breathing-app__circle[data-motion='wave'] .breathing-app__ring--2 {
      transition: none;
      animation: breathing-wave-mid var(--breathing-cycle-ms)
        var(--ease-precise) infinite;
    }

    .breathing-app__circle[data-motion='wave'] .breathing-app__ring--3 {
      transition: none;
      animation: breathing-wave-inner var(--breathing-cycle-ms)
        var(--ease-precise) infinite;
    }

    .breathing-app__circle[data-motion='hold-high'] .breathing-app__ring--1 {
      --ring-scale: 1.04;
    }

    .breathing-app__circle[data-motion='hold-high'] .breathing-app__ring--2 {
      --ring-scale: 1.3;
    }

    .breathing-app__circle[data-motion='hold-high'] .breathing-app__ring--3 {
      --ring-scale: 1.9;
    }

    .breathing-app__circle[data-motion='hold-low'] .breathing-app__ring--1 {
      --ring-scale: 0.98;
    }

    .breathing-app__circle[data-motion='hold-low'] .breathing-app__ring--2 {
      --ring-scale: 0.95;
    }

    .breathing-app__circle[data-motion='hold-low'] .breathing-app__ring--3 {
      --ring-scale: 0.9;
    }

    .breathing-app__core {
      position: absolute;
      inset: 48%;
      background: radial-gradient(
        circle at 35% 30%,
        color-mix(in oklch, var(--breathing-accent) 92%, var(--color-bone) 8%),
        color-mix(in oklch, var(--breathing-accent) 70%, transparent) 60%,
        color-mix(in oklch, var(--breathing-accent-dim) 50%, transparent) 100%
      );
      border-radius: var(--radius-full);
      box-shadow:
        0 0 60px color-mix(in oklch, var(--breathing-accent) 55%, transparent),
        0 0 120px color-mix(in oklch, var(--breathing-accent) 25%, transparent);
      mix-blend-mode: screen;
      transition:
        background var(--duration-slower) var(--ease-settle),
        box-shadow var(--duration-slower) var(--ease-settle);
    }

    .breathing-app[data-phase='retention'] {
      --breathing-accent: var(--color-sage-light);
      --breathing-accent-dim: var(--color-sage);
    }

    .breathing-app[data-phase='recovery'] {
      --breathing-accent: var(--color-sand-light);
      --breathing-accent-dim: var(--color-sand);
    }

    .breathing-app[data-phase='complete'] {
      --breathing-accent: var(--color-terracotta-light);
      --breathing-accent-dim: var(--color-terracotta);
    }

    .breathing-app__label {
      position: relative;
      z-index: 2;
      display: grid;
      gap: var(--space-2xs);
      padding: var(--space-sm) var(--space-md);
      pointer-events: none;
    }

    .breathing-app__phase {
      display: block;
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 6vw, 2.5rem);
      font-weight: 500;
      color: var(--text-on-dark);
      letter-spacing: 0.01em;
      text-shadow: 0 2px 24px color-mix(in oklch, black 70%, transparent);
    }

    .breathing-app__counter {
      display: block;
      font-size: 0.8125rem;
      font-weight: 500;
      color: color-mix(in oklch, var(--text-on-dark) 70%, transparent);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .breathing-app__meta {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-sm);
      text-align: center;
    }

    .breathing-app__meta-item {
      display: grid;
      gap: var(--space-3xs);
      padding-block: var(--space-xs);
      border-block-start: 1px solid
        color-mix(in oklch, var(--color-sand) 14%, transparent);
    }

    .breathing-app__meta-label {
      font-size: 0.6875rem;
      font-weight: 500;
      color: color-mix(in oklch, var(--text-on-dark) 48%, transparent);
      text-transform: uppercase;
      letter-spacing: 0.14em;
    }

    .breathing-app__meta-value {
      font-family: var(--font-display);
      font-size: clamp(1.125rem, 3vw, 1.375rem);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
      color: var(--text-on-dark);
    }

    .breathing-app__controls {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
      align-items: center;
      justify-content: center;
    }

    .breathing-app__controls .btn {
      min-block-size: 52px;
    }

    .breathing-app__start svg {
      margin-inline-start: 3px;
    }

    /* Sound toggle — compact, square ghost icon button. */
    .breathing-app__sound {
      --btn-padding-inline: var(--space-xs);

      aspect-ratio: 1;
    }

    .breathing-app__sound svg {
      inline-size: 1.4rem;
      block-size: 1.4rem;
    }

    .breathing-app__settings {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
