---
import Layout from '../layouts/Layout.astro';
import { fetchNextEvent } from '@lib/server/events';
import { buildEventSchema } from '@lib/event-schema';
import EventPage from '../components/islands/EventPage.svelte';
import site from '../data/site.json';

// SSR: the next upcoming event (incl. live capacity) is fetched from PocketBase
// per request, so /event always reflects the current "next" event with no
// rebuild. `null` renders the graceful "no termin scheduled" state.
const event = await fetchNextEvent();

// When an upcoming event exists, redirect to its canonical slug URL
// (/event/<slug>) so the event always lives at a single, shareable URL.
// Without a slug we fall through and render the next event inline.
if (event?.slug) return Astro.redirect(`/event/${event.slug}`, 302);

// Emit Event structured data when a concrete upcoming event exists, so the
// page is eligible for an Event rich result (date, place, availability).
const schemas = event ? [buildEventSchema(event, Astro.site ?? new URL('https://mens-circle.de'))] : [];
---

<Layout
  title="Termin & Anmeldung – Männerkreis Niederbayern/ Straubing"
  description="Der nächste Männerkreis in Straubing. Sieh dir den Termin an und sichere dir deinen Platz."
  ogType="event"
  schemas={schemas}
>
  <EventPage client:load event={event} whatsappLink={site.whatsappCommunityLink} />
</Layout>
