---
import Layout from '../../layouts/Layout.astro';
import { getEventBySlug } from '@lib/pocketbase-server';
import EventPage from '../../components/islands/EventPage.svelte';
import site from '../../data/site.json';

// SSR: one page per event (date-based slug, e.g. /event/2026-06-12), covering
// past and upcoming events. The record is fetched from PocketBase per request,
// so new/edited events get a live page with no rebuild. An unknown slug falls
// back to /event (the current "next" event).
const { slug } = Astro.params;
const event = slug ? await getEventBySlug(slug) : null;
if (!event) return Astro.redirect('/event', 302);

const cleanTitle = event.title?.trim() || 'Termin';
---

<Layout
  title={`${cleanTitle} – Männerkreis Niederbayern/ Straubing`}
  description={`${cleanTitle} in ${event.location || 'Straubing'}. Sieh dir den Termin an und sichere dir deinen Platz.`}
  ogType="event"
>
  <EventPage
    client:load
    event={event}
    whatsappLink={site.whatsappCommunityLink}
  />
</Layout>
