---
import Layout from '../layouts/Layout.astro';
import type { Block } from '../components/PageContent.astro';
import PageContent from '../components/PageContent.astro';
import home from '../content/home.json';

// Prerendered (static): served straight off disk by the Bun server, and the
// Moderator image is optimized at BUILD time (no runtime /_image endpoint). The only
// live part — the testimonials — is a server island (see PageContent.astro).
export const prerender = true;

const blocks = home.blocks as Block[];

// Strip inline HTML from titles for schema text.
const strip = (s = '') => s.replace(/<[^>]*>/g, '').trim();

// Build per-page structured data from the content blocks.
const schemas: Record<string, unknown>[] = [];

const journey = blocks.find((b) => b.type === 'journey-steps');
if (journey?.data?.steps?.length) {
  // The journey steps describe the flow of a meeting, not an actionable
  // procedure — and Google retired HowTo rich results in 2023, so HowTo markup
  // no longer earns any SERP feature. ItemList is the valid, machine-readable
  // representation that still feeds AI/LLM understanding of the steps.
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: strip(journey.data.title) || 'Deine Reise zum Männerkreis',
    description: journey.data.subtitle ?? 'Wie du Teil des Männerkreis wirst',
    itemListElement: journey.data.steps.map((s: { title?: string; description?: string }, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: s.title ?? '',
      description: s.description ?? '',
    })),
  });
}

const faq = blocks.find((b) => b.type === 'faq');
if (faq?.data?.items?.length) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.data.items
      .filter((i: { question?: string; answer?: string }) => i.question && i.answer)
      .map((i: { question?: string; answer?: string }) => ({
        '@type': 'Question',
        name: i.question,
        acceptedAnswer: { '@type': 'Answer', text: strip(i.answer) },
      })),
  });
}
---

<Layout title={home.meta.title} description={home.meta.description} keywords={home.meta.keywords} schemas={schemas}>
  <PageContent blocks={blocks} />
</Layout>
