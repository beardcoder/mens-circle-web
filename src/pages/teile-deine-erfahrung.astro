---
import Layout from '../layouts/Layout.astro';
import TestimonialForm from '../components/islands/TestimonialForm.svelte';

// Static form page (submits client-side to PocketBase) — prerendered at build.
export const prerender = true;

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: '/' },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Teile deine Erfahrung',
        item: '/teile-deine-erfahrung',
      },
    ],
  },
];
---

<Layout
  title="Teile deine Erfahrung – Männerkreis Niederbayern/ Straubing"
  description="Teile deine Erfahrung mit dem Männerkreis Niederbayern/ Straubing. Hilf anderen Männern zu verstehen, was der Kreis bedeuten kann."
  schemas={schemas}
>
  <section class="hero testimonial-form-hero">
    <div class="hero__bg"></div>
    <div class="container">
      <div class="hero__content">
        <p class="hero__label">Community Stimmen</p>
        <h1 class="hero__title">
          Teile deine <span class="highlight">Erfahrung</span>
        </h1>
        <p class="hero__subtitle">Deine Geschichte kann anderen Männern Mut machen, den ersten Schritt zu wagen.</p>
      </div>
    </div>
  </section>

  <section class="section testimonial-form-section">
    <div class="container">
      <div class="testimonial-form__wrapper">
        <div class="testimonial-form__intro">
          <h2>Deine Stimme zählt</h2>
          <p>
            Der Männerkreis lebt von authentischen Begegnungen. Wenn du Teil unserer Community bist und deine Erfahrung
            teilen möchtest, würden wir uns freuen, von dir zu hören.
          </p>
          <p>
            Dein Testimonial wird nach Prüfung auf unserer Website veröffentlicht und kann anderen Männern helfen zu
            verstehen, was der Kreis bedeuten kann.
          </p>
        </div>

        <TestimonialForm client:visible />
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  @layer sections {
    .testimonial-form-hero {
      --_surface-noise-opacity: 0.04;

      position: relative;
      background: linear-gradient(
        135deg,
        var(--color-earth-deep) 0%,
        color-mix(in oklch, var(--color-earth-deep) 90%, var(--color-terracotta)) 100%
      );
      block-size: 100vh;
      min-block-size: 50vh;
      color: var(--text-on-dark);
    }

    .testimonial-form-section {
      background: var(--bg-secondary);
    }

    .testimonial-form__wrapper {
      margin-inline: auto;
      max-inline-size: var(--content-max-wide);
    }

    .testimonial-form__intro {
      margin-block-end: var(--space-xl);
      text-align: center;
    }

    .testimonial-form__intro h2 {
      margin-block-end: var(--space-md);
      color: var(--text-primary);
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-family: var(--font-display);
    }

    .testimonial-form__intro p {
      margin-block-end: var(--space-md);
      color: var(--text-muted);
      font-size: var(--text-section-body);
      line-height: var(--leading-relaxed);
    }

    .testimonial-form__intro p:last-child {
      margin-block-end: 0;
    }

    .testimonial-form {
      box-shadow: var(--shadow-md);
      border-radius: var(--radius-lg);
      background: var(--bg-elevated);
      padding: var(--space-lg);
    }

    @media (width <= 600px) {
      .testimonial-form {
        padding: var(--space-md);
      }
    }

    .testimonial-form__counter {
      position: absolute;
      inset-block-end: calc(var(--space-sm) + var(--space-xs));
      inset-inline-end: var(--space-md);
      pointer-events: none;
      color: var(--text-muted);
      font-size: 0.8125rem;
    }

    .testimonial-form .form-actions .btn {
      min-inline-size: 200px;
    }

    .testimonial-form__note {
      margin-block-start: var(--space-md);
      color: var(--text-muted);
      font-size: 0.875rem;
      line-height: 1.6;
      text-align: center;
    }
  }
</style>
