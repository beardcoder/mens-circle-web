{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "drizzle"],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "types": ["leaflet", "bun"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@components/*": ["src/components/*"],
      "@data/*": ["src/data/*"]
    }
  }
}
